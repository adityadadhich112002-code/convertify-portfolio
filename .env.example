# Google Sheets Web App URL (deployed from extensions -> Apps Script)
PUBLIC_GOOGLE_SHEETS_URL=https://script.google.com/macros/s/xxxx/exec

# Meta (Facebook) Pixel ID
PUBLIC_META_PIXEL_ID=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console HTML verification tag content (from Google Search Console -> HTML Tag option)
PUBLIC_GOOGLE_SITE_VERIFICATION=
