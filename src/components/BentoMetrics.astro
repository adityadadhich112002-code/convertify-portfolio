---
---

<section id="metrics-bento" class="relative bg-canvas py-24 md:py-32 px-6 md:px-16 overflow-hidden select-none">
  <!-- Glowing spotlight background -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90vw] max-w-[800px] h-[80%] bg-radial from-brand-blue/6 via-brand-blue/1 to-transparent blur-[100px] pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto">
    <!-- Header Label -->
    <div class="bento-header opacity-0 translate-y-8 flex flex-col items-center text-center gap-4 mb-16 select-none">
      <span class="flex items-center gap-3 text-[10px] md:text-[11px] font-display font-medium tracking-[0.25em] uppercase text-brand-blue mb-2">
        <span class="w-5 h-[1px] bg-brand-blue"></span>
        Metrics Matter
        <span class="w-5 h-[1px] bg-brand-blue"></span>
      </span>
      <h2 class="text-center select-none text-[40px] xs:text-[44px] sm:text-[54px] md:text-[72px] text-white font-bold leading-[1.15] md:leading-[1.2] tracking-[-0.04em] font-display">
        <!-- Line 1: Here are the -->
        <span class="block md:inline whitespace-nowrap">Here are the</span>
        <!-- Line 2: Numbers for you -->
        <span class="block md:inline md:ml-3 whitespace-nowrap">
          <span class="relative inline-block py-1 text-white font-bold" id="scramble-word-container">
            <span id="bento-scramble-word" class="relative z-10 inline-block min-w-[7ch]">9842150</span>
            <!-- Dynamic Animated Double Underline Scribbles from Hero -->
            <svg class="absolute left-[-15%] bottom-[-14%] w-[130%] h-[0.38em] overflow-visible pointer-events-none" viewBox="0 0 100 15" fill="none" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
              <path id="bento-marker-path" class="stroke-red-600 stroke-[3.5] stroke-linecap-round" d="M0 9 C30 2, 70 2, 100 6" stroke-dasharray="100" stroke-dashoffset="100"></path>
              <path id="bento-marker-path-2" class="stroke-red-600/80 stroke-[2] stroke-linecap-round" d="M2 12 C32 6, 68 6, 98 10" stroke-dasharray="100" stroke-dashoffset="100"></path>
            </svg>
          </span>
          <span class="inline-block font-script font-bold italic text-brand-blue text-[1.12em] tracking-normal not-italic ml-1">
            for you
          </span>
        </span>
      </h2>
    </div>

    <!-- Bento Grid (3-column layout on desktop, 1-column on mobile) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative z-10">
      
      <!-- Card 1: Conversion Rate Lift (2x, Col span 2) -->
      <div class="bento-card cursor-pointer relative group md:col-span-2 p-8 rounded-2xl overflow-hidden transition-all duration-400 min-h-[200px] flex flex-col justify-between opacity-0 translate-y-12" data-bento-card="lift">
        <div class="spotlight-layer absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-[radial-gradient(circle_at_var(--x,_50%)_var(--y,_50%),rgba(20,0,255,0.08)_0%,transparent_60%)] z-[2]" aria-hidden="true"></div>
        
        <div class="flex flex-col gap-1 relative z-10">
          <span class="font-display text-[64px] sm:text-[72px] md:text-[84px] font-bold text-white leading-none tracking-tighter">
            2<span class="text-brand-blue">×</span>
          </span>
          <h3 class="font-display text-[18px] md:text-[20px] font-bold text-white tracking-tight mt-3">Conversion Rate Lift</h3>
          <p class="text-[12px] md:text-[13px] text-white/45 leading-relaxed max-w-[420px] mt-1">
            Average growth reported by our clients. By migrating from template-based themes to custom, speed-optimized visual paths.
          </p>
        </div>
      </div>

      <!-- Card 2: Countries Connected (5+, Col span 1) -->
      <div class="bento-card cursor-pointer relative group p-8 rounded-2xl overflow-hidden transition-all duration-400 min-h-[200px] flex flex-col justify-between opacity-0 translate-y-12" data-bento-card="countries">
        <div class="spotlight-layer absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-[radial-gradient(circle_at_var(--x,_50%)_var(--y,_50%),rgba(20,0,255,0.08)_0%,transparent_60%)] z-[2]" aria-hidden="true"></div>
        
        <div class="flex flex-col gap-1 relative z-10">
          <span class="font-display text-[64px] sm:text-[72px] md:text-[84px] font-bold text-white leading-none tracking-tighter">
            5<span class="text-brand-blue">+</span>
          </span>
          <h3 class="font-display text-[18px] md:text-[20px] font-bold text-white tracking-tight mt-3">Countries Connected</h3>
          <p class="text-[12px] md:text-[13px] text-white/45 leading-relaxed mt-1">
            Global collaborative reach across teams and partner specialists based in India, USA, UK, UAE, and Australia.
          </p>
        </div>
      </div>

      <!-- Card 3: Delivered Scale (437+, Col span 1) -->
      <div class="bento-card cursor-pointer relative group p-8 rounded-2xl overflow-hidden transition-all duration-400 min-h-[200px] flex flex-col justify-between opacity-0 translate-y-12" data-bento-card="delivered">
        <div class="spotlight-layer absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-[radial-gradient(circle_at_var(--x,_50%)_var(--y,_50%),rgba(20,0,255,0.08)_0%,transparent_60%)] z-[2]" aria-hidden="true"></div>
        
        <div class="flex flex-col gap-1 relative z-10">
          <span class="font-display text-[64px] sm:text-[72px] md:text-[84px] font-bold text-white leading-none tracking-tighter">
            437<span class="text-brand-blue">+</span>
          </span>
          <h3 class="font-display text-[18px] md:text-[20px] font-bold text-white tracking-tight mt-3">Websites Delivered</h3>
          <p class="text-[12px] md:text-[13px] text-white/45 leading-relaxed mt-1">
            Engineered at scale across high-volume Ecommerce portals, B2B SaaS, and Personal Brands.
          </p>
        </div>
      </div>

      <!-- Card 4: Success Ratio (100%, Col span 2) -->
      <div class="bento-card cursor-pointer relative group md:col-span-2 p-8 rounded-2xl overflow-hidden transition-all duration-400 min-h-[200px] flex flex-col justify-between opacity-0 translate-y-12" data-bento-card="success">
        <div class="spotlight-layer absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-[radial-gradient(circle_at_var(--x,_50%)_var(--y,_50%),rgba(20,0,255,0.08)_0%,transparent_60%)] z-[2]" aria-hidden="true"></div>
        
        <div class="flex flex-col gap-1 relative z-10">
          <span class="font-display text-[64px] sm:text-[72px] md:text-[84px] font-bold text-white leading-none tracking-tighter">
            100<span class="text-brand-blue">%</span>
          </span>
          <h3 class="font-display text-[18px] md:text-[20px] font-bold text-white tracking-tight mt-3">Client Success Ratio</h3>
          <p class="text-[12px] md:text-[13px] text-white/45 leading-relaxed max-w-[420px] mt-1">
            Every client launched a web application aligned with their core commercial targets, backed by continuous post-launch design support.
          </p>
        </div>
      </div>

      <!-- Card 5: Agencies Partnered (12+, Col span 1) -->
      <div class="bento-card cursor-pointer relative group p-8 rounded-2xl overflow-hidden transition-all duration-400 min-h-[200px] flex flex-col justify-between opacity-0 translate-y-12" data-bento-card="agencies">
        <div class="spotlight-layer absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-[radial-gradient(circle_at_var(--x,_50%)_var(--y,_50%),rgba(20,0,255,0.08)_0%,transparent_60%)] z-[2]" aria-hidden="true"></div>
        
        <div class="flex flex-col gap-1 relative z-10">
          <span class="font-display text-[64px] sm:text-[72px] md:text-[84px] font-bold text-white leading-none tracking-tighter">
            12<span class="text-brand-blue">+</span>
          </span>
          <h3 class="font-display text-[18px] md:text-[20px] font-bold text-white tracking-tight mt-3">Agencies Partnered</h3>
          <p class="text-[12px] md:text-[13px] text-white/45 leading-relaxed mt-1">
            Collaborating with specialist web design and engineering firms globally to scale deliverable throughput.
          </p>
        </div>
      </div>

      <!-- Card 6: Increased Trust Sentiment (98%, Col span 1) -->
      <div class="bento-card cursor-pointer relative group p-8 rounded-2xl overflow-hidden transition-all duration-400 min-h-[200px] flex flex-col justify-between opacity-0 translate-y-12" data-bento-card="trust">
        <div class="spotlight-layer absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-[radial-gradient(circle_at_var(--x,_50%)_var(--y,_50%),rgba(20,0,255,0.08)_0%,transparent_60%)] z-[2]" aria-hidden="true"></div>
        
        <div class="flex flex-col gap-1 relative z-10">
          <span class="font-display text-[64px] sm:text-[72px] md:text-[84px] font-bold text-white leading-none tracking-tighter">
            98<span class="text-brand-blue">%</span>
          </span>
          <h3 class="font-display text-[18px] md:text-[20px] font-bold text-white tracking-tight mt-3">Increased Trust</h3>
          <p class="text-[12px] md:text-[13px] text-white/45 leading-relaxed mt-1">
            Reported growth in brand trust index scores based on customer feedback surveys post-launch.
          </p>
        </div>
      </div>

      <!-- Card 7: Years of Experience (7+, Col span 1) -->
      <div class="bento-card cursor-pointer relative group p-8 rounded-2xl overflow-hidden transition-all duration-400 min-h-[200px] flex flex-col justify-between opacity-0 translate-y-12" data-bento-card="experience">
        <div class="spotlight-layer absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-[radial-gradient(circle_at_var(--x,_50%)_var(--y,_50%),rgba(20,0,255,0.08)_0%,transparent_60%)] z-[2]" aria-hidden="true"></div>
        
        <div class="flex flex-col gap-1 relative z-10">
          <span class="font-display text-[64px] sm:text-[72px] md:text-[84px] font-bold text-white leading-none tracking-tighter">
            7<span class="text-brand-blue">+</span>
          </span>
          <h3 class="font-display text-[18px] md:text-[20px] font-bold text-white tracking-tight mt-3">Years of Experience</h3>
          <p class="text-[12px] md:text-[13px] text-white/45 leading-relaxed mt-1">
            Fine-tuning design principles, custom performance configurations, and copywriting systems.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .font-poppins {
    font-family: 'Poppins', sans-serif;
  }
  .font-montserrat {
    font-family: 'Montserrat', sans-serif;
  }

  /* Glassy Bento Cards */
  .bento-card {
    background: rgba(15, 15, 20, 0.55) !important;
    backdrop-filter: blur(40px) saturate(220%) !important;
    -webkit-backdrop-filter: blur(40px) saturate(220%) !important;
    border: 1.5px solid transparent !important;
    background-clip: padding-box, border-box !important;
    background-origin: padding-box, border-box !important;
    background-image:
      linear-gradient(rgba(15, 15, 20, 0.65), rgba(15, 15, 20, 0.85)) padding-box,
      linear-gradient(135deg, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0.1) 25%, rgba(255, 255, 255, 0.45) 50%, rgba(255, 255, 255, 0.06) 75%, rgba(255, 255, 255, 0.35) 100%) border-box !important;
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.6),
      0 4px 16px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -1px 0 rgba(255, 255, 255, 0.03) !important;
    transition:
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      background-image 0.4s ease !important;
  }

  .bento-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, transparent 100%);
    border-radius: inherit;
    pointer-events: none;
    z-index: 1;
  }

  .bento-card:hover {
    transform: translateY(-4px) !important;
    background-image:
      linear-gradient(rgba(18, 18, 24, 0.7), rgba(10, 10, 15, 0.9)) padding-box,
      linear-gradient(135deg, rgba(255, 255, 255, 0.75) 0%, rgba(255, 255, 255, 0.18) 25%, rgba(255, 255, 255, 0.6) 50%, rgba(255, 255, 255, 0.1) 75%, rgba(255, 255, 255, 0.45) 100%) border-box !important;
    box-shadow:
      0 0 0 1px rgba(0, 153, 255, 0.2),
      0 24px 64px rgba(0, 0, 0, 0.8),
      0 8px 24px rgba(0, 153, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.12) !important;
  }
</style>
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initBentoAnimations = () => {
    const section = document.getElementById('metrics-bento');
    if (!section) return;

    // 1. Header fade up and scramble trigger
    gsap.to('.bento-header', {
      opacity: 1,
      y: 0,
      duration: 1.0,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: section,
        start: 'top 75%',
        onEnter: () => {
          startScramble();
        }
      }
    });

    // 2. Bento cards staggered reveal
    gsap.fromTo('.bento-card', 
      { opacity: 0, y: 40 },
      { 
        opacity: 1, 
        y: 0, 
        stagger: 0.1, 
        duration: 1.0, 
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '#metrics-bento',
          start: 'top 65%'
        },
        onComplete: () => {
          // Trigger internal widget animations once grid renders
          initWidgets();
        }
      }
    );

    // 3. Mouse spotlight coordination tracking
    const cards = section.querySelectorAll('.bento-card');
    const isTouch = window.matchMedia('(hover: none)').matches;

    if (!isTouch) {
      cards.forEach(card => {
        card.addEventListener('mousemove', (e: any) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          card.style.setProperty('--x', `${x}px`);
          card.style.setProperty('--y', `${y}px`);
        });
      });
    }
  };

  // Start scramble numbers animation
  const startScramble = () => {
    const scrambleWord = document.getElementById('bento-scramble-word');
    if (!scrambleWord) return;

    const finalWord = "Numbers";
    const chars = "0123456789";
    const duration = 1500; // ms (prior shuffle duration)
    let startTime = null;

    const animate = (timestamp) => {
      if (!startTime) startTime = timestamp;
      const progress = (timestamp - startTime) / duration;

      if (progress < 1) {
        let result = "";
        const length = finalWord.length;
        const lockCount = Math.floor(progress * length);

        for (let i = 0; i < length; i++) {
          if (i < lockCount) {
            result += finalWord[i];
          } else {
            result += chars[Math.floor(Math.random() * chars.length)];
          }
        }
        scrambleWord.textContent = result;
        requestAnimationFrame(animate);
      } else {
        scrambleWord.textContent = finalWord;

        // Trigger marker drawing animation for both double lines
        const marker1 = document.getElementById('bento-marker-path') as any;
        const marker2 = document.getElementById('bento-marker-path-2') as any;
        
        if (marker1 && marker2) {
          const length1 = marker1.getTotalLength();
          const length2 = marker2.getTotalLength();
          
          gsap.set(marker1, { strokeDasharray: length1, strokeDashoffset: length1 });
          gsap.set(marker2, { strokeDasharray: length2, strokeDashoffset: length2 });
          
          gsap.to(marker1, {
            strokeDashoffset: 0,
            duration: 0.8,
            ease: 'power2.out'
          });
          
          gsap.to(marker2, {
            strokeDashoffset: 0,
            duration: 0.8,
            ease: 'power2.out',
            delay: 0.3
          });
        }
      }
    };

    requestAnimationFrame(animate);
  };

  // Internal widget animations (Gauge swipe)
  const initWidgets = () => {
    // 1. Circular Success Ratio gauge radial sweep
    const gauge = document.getElementById('bento-gauge');
    if (gauge) {
      gsap.to(gauge, {
        strokeDashoffset: 0,
        duration: 1.0,
        ease: 'power2.out'
      });
    }

    // 2. SVG line chart draw-in
    const lineChart = document.getElementById('bento-chart-lift');
    if (lineChart) {
      const length = lineChart.getTotalLength();
      gsap.set(lineChart, { strokeDasharray: length, strokeDashoffset: length });
      gsap.to(lineChart, {
        strokeDashoffset: 0,
        duration: 1.0,
        ease: 'power2.out'
      });
    }

    // Set up hover and click triggers for interactive widgets
    const cards = document.querySelectorAll('.bento-card');
    cards.forEach(card => {
      const type = card.getAttribute('data-bento-card');
      if (!type) return;

      card.addEventListener('mouseenter', () => {
        triggerWidgetAnimation(type, 'hover');
      });

      card.addEventListener('click', () => {
        triggerWidgetAnimation(type, 'click');
      });
    });
  };

  const triggerWidgetAnimation = (type, trigger) => {
    switch (type) {
      case 'lift': {
        const path = document.getElementById('bento-chart-lift');
        if (path) {
          const length = path.getTotalLength();
          if (trigger === 'click') {
            gsap.fromTo(path, 
              { strokeDashoffset: length },
              { strokeDashoffset: 0, duration: 1.0, ease: 'power2.out' }
            );
          } else {
            gsap.fromTo(path, 
              { scaleY: 0.9, transformOrigin: "bottom center" },
              { scaleY: 1.1, duration: 0.3, yoyo: true, repeat: 1, ease: 'power1.inOut' }
            );
          }
        }
        break;
      }
      case 'countries': {
        const dots = document.querySelectorAll('[data-bento-card="countries"] circle');
        if (dots.length > 0) {
          if (trigger === 'click') {
            gsap.fromTo(dots, 
              { scale: 0.6, transformOrigin: "center center" },
              { scale: 1.5, stagger: 0.05, duration: 0.5, yoyo: true, repeat: 1, ease: 'power2.out' }
            );
          } else {
            gsap.fromTo(dots, 
              { scale: 1, transformOrigin: "center center" },
              { scale: 1.3, duration: 0.3, stagger: 0.05, ease: 'power1.out', yoyo: true, repeat: 1 }
            );
          }
        }
        break;
      }
      case 'delivered': {
        const badges = document.querySelectorAll('.bento-badge');
        if (badges.length > 0) {
          if (trigger === 'click') {
            gsap.fromTo(badges, 
              { rotateX: 0 },
              { rotateX: 360, stagger: 0.1, duration: 0.8, ease: 'back.out(1.5)' }
            );
          } else {
            gsap.fromTo(badges, 
              { y: 0 },
              { y: -6, stagger: 0.08, duration: 0.25, yoyo: true, repeat: 1, ease: 'power1.inOut' }
            );
          }
        }
        break;
      }
      case 'success': {
        const gauge = document.getElementById('bento-gauge');
        const text = document.getElementById('bento-gauge-text');
        if (gauge) {
          if (trigger === 'click') {
            gsap.fromTo(gauge, 
              { strokeDashoffset: 251.2 },
              { strokeDashoffset: 0, duration: 1.2, ease: 'power2.inOut' }
            );
            if (text) {
              gsap.fromTo(text, 
                { scale: 0.8 },
                { scale: 1.2, duration: 0.3, yoyo: true, repeat: 1, ease: 'back.out' }
              );
            }
          } else {
            if (text) {
              gsap.fromTo(text, 
                { scale: 1 },
                { scale: 1.15, duration: 0.25, yoyo: true, repeat: 1, ease: 'power1.out' }
              );
            }
          }
        }
        break;
      }
      case 'agencies': {
        const nodes = document.querySelectorAll('[data-bento-card="agencies"] circle');
        const lines = document.querySelectorAll('[data-bento-card="agencies"] line');
        if (nodes.length > 0) {
          if (trigger === 'click') {
            gsap.fromTo(nodes, 
              { x: 0, y: 0 },
              { 
                x: () => (Math.random() - 0.5) * 20, 
                y: () => (Math.random() - 0.5) * 20, 
                duration: 0.3, 
                yoyo: true, 
                repeat: 1, 
                ease: 'power2.out' 
              }
            );
            gsap.fromTo(lines, 
              { opacity: 0.12 },
              { opacity: 0.4, duration: 0.3, yoyo: true, repeat: 1 }
            );
          } else {
            gsap.fromTo(nodes, 
              { y: 0 },
              { y: -4, stagger: 0.04, duration: 0.3, yoyo: true, repeat: 1, ease: 'power1.inOut' }
            );
          }
        }
        break;
      }
      case 'trust': {
        const stars = document.querySelectorAll('.bento-star');
        if (stars.length > 0) {
          if (trigger === 'click') {
            gsap.fromTo(stars, 
              { y: 0 },
              { y: -8, duration: 0.4, stagger: 0.06, ease: 'bounce.out', yoyo: true, repeat: 1 }
            );
          } else {
            gsap.fromTo(stars, 
              { scale: 1, filter: 'drop-shadow(0 0 4px rgba(20,0,255,0.4))' },
              { scale: 1.3, filter: 'drop-shadow(0 0 10px rgba(20,0,255,0.8))', stagger: 0.05, duration: 0.2, yoyo: true, repeat: 1 }
            );
          }
        }
        break;
      }
      case 'experience': {
        const calendar = document.getElementById('bento-calendar-svg');
        if (calendar) {
          if (trigger === 'click') {
            gsap.fromTo(calendar, 
              { rotateY: 0 },
              { rotateY: 360, duration: 1.0, ease: 'power3.out' }
            );
          } else {
            gsap.fromTo(calendar, 
              { rotation: 0 },
              { rotation: 10, duration: 0.2, yoyo: true, repeat: 1, ease: 'power1.inOut' }
            );
          }
        }
        break;
      }
    }
  };

  window.addEventListener('loaderComplete', initBentoAnimations);
</script>
