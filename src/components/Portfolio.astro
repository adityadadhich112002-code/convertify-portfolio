</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const initPortfolioAnimations = () => {

    // Header entrance
    gsap.to('.portfolio-eyebrow', {
      opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      scrollTrigger: { trigger: '#portfolio', start: 'top 75%' }
    });
    gsap.to('.portfolio-heading', {
      opacity: 1, y: 0, duration: 1.0, ease: 'power3.out', delay: 0.1,
      scrollTrigger: { trigger: '#portfolio', start: 'top 75%' }
    });
    gsap.to('.portfolio-stats', {
      opacity: 1, y: 0, duration: 0.9, ease: 'power3.out', delay: 0.2,
      scrollTrigger: { trigger: '#portfolio', start: 'top 75%' }
    });
    gsap.to('#portfolio-click-helper', {
      opacity: 0.95, y: 0, duration: 0.8, ease: 'power3.out', delay: 0.15,
      scrollTrigger: { trigger: '#portfolio', start: 'top 75%' }
    });


    // ── PORTFOLIO word: mobile-only photo-reel → text reveal ──
    const portfolioWord    = document.getElementById('portfolio-word');
    const portfolioShimmer = document.getElementById('portfolio-shimmer');
    const photoReel        = document.getElementById('portfolio-photo-reel');
    const reelPhotos       = document.querySelectorAll('.reel-photo');
    const isMobile         = window.matchMedia('(max-width: 639px)').matches;

    if (portfolioWord && isMobile && photoReel) {

      // Helper to retrieve or create the globally shared AudioContext
      const getSharedContext = () => {
        const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
        if (!AudioContextClass) return null;
        if (!(window as any).sharedAudioCtx) {
          (window as any).sharedAudioCtx = new AudioContextClass();
        }
        return (window as any).sharedAudioCtx;
      };

      // Synthesize camera mechanical click sound using Web Audio API
      const playCameraClickSound = () => {
        try {
          const ctx = getSharedContext();
          if (!ctx) return;
          if (ctx.state === 'suspended') {
            ctx.resume();
          }
          
          const playClick = (timeOffset: number) => {
            const bufferSize = ctx.sampleRate * 0.05; // 50ms click duration
            const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
            const data = buffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) {
              data[i] = Math.random() * 2 - 1;
            }
            
            const noise = ctx.createBufferSource();
            noise.buffer = buffer;
            
            const filter = ctx.createBiquadFilter();
            filter.type = 'bandpass';
            filter.frequency.value = 2200; // Bright camera mechanical sound
            filter.Q.value = 4;
            
            const gain = ctx.createGain();
            const now = ctx.currentTime + timeOffset;
            gain.gain.setValueAtTime(0, now);
            gain.gain.linearRampToValueAtTime(0.16, now + 0.001); // Peak gain to 0.16 (16%)
            gain.gain.exponentialRampToValueAtTime(0.001, now + 0.035); // Very fast decay
            
            noise.connect(filter);
            filter.connect(gain);
            gain.connect(ctx.destination);
            noise.start(now);
            noise.stop(now + 0.04);
          };

          // Simulate dual-shutter click (shutter opening and closing)
          playClick(0);
          playClick(0.02);
        } catch (e) {
          // Silent fallback if Web Audio is blocked or unsupported
        }
      };

      // Synthesize heavy mechanical shutter slam
      const playSlamSound = () => {
        try {
          const ctx = getSharedContext();
          if (!ctx) return;
          if (ctx.state === 'suspended') {
            ctx.resume();
          }
          
          // Heavy bass thud
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          
          osc.type = 'sine';
          const now = ctx.currentTime;
          
          osc.frequency.setValueAtTime(120, now); // Start at 120Hz
          osc.frequency.exponentialRampToValueAtTime(40, now + 0.25); // Sweep down to 40Hz
          
          gain.gain.setValueAtTime(0, now);
          gain.gain.linearRampToValueAtTime(0.24, now + 0.005); // Peak thud gain to 0.24 (24%)
          gain.gain.exponentialRampToValueAtTime(0.001, now + 0.4); // Medium decay
          
          // Add a high-freq mechanical click layer for the slam
          const bufferSize = ctx.sampleRate * 0.08;
          const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
          const data = buffer.getChannelData(0);
          for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;
          
          const noise = ctx.createBufferSource();
          noise.buffer = buffer;
          
          const filter = ctx.createBiquadFilter();
          filter.type = 'bandpass';
          filter.frequency.value = 1500;
          filter.Q.value = 2;
          
          const noiseGain = ctx.createGain();
          noiseGain.gain.setValueAtTime(0, now);
          noiseGain.gain.linearRampToValueAtTime(0.16, now + 0.002); // Peak noise click gain to 0.16 (16%)
          noiseGain.gain.exponentialRampToValueAtTime(0.001, now + 0.08);
          
          noise.connect(filter);
          filter.connect(noiseGain);
          noiseGain.connect(ctx.destination);
          
          osc.connect(gain);
          gain.connect(ctx.destination);
          
          osc.start(now);
          osc.stop(now + 0.45);
          noise.start(now);
          noise.stop(now + 0.1);
        } catch (e) {}
      };

      // ── Reusable play function (called on scroll + on click) ──
      const playReelAnimation = () => {
        // Kill any running tweens on these elements
        gsap.killTweensOf([portfolioWord, portfolioShimmer, photoReel, ...Array.from(reelPhotos), '#portfolio-click-helper']);

        // Reset state
        gsap.set(photoReel,       { opacity: 1 });
        gsap.set(reelPhotos,      { opacity: 0 });
        gsap.set(portfolioWord,   { opacity: 0, scaleY: 0.82, letterSpacing: '0.55em' });
        gsap.set(portfolioShimmer,{ opacity: 0, x: '-110%' });
        gsap.set('#portfolio-click-helper', { opacity: 0, y: 10 });

        const tl = gsap.timeline({
          onComplete: () => {
            // Phase 3 – looping breath
            gsap.to(portfolioWord, {
              letterSpacing: '-0.02em',
              duration: 2.8,
              ease: 'sine.inOut',
              yoyo: true,
              repeat: -1
            });
            // Fade in click helper
            gsap.to('#portfolio-click-helper', {
              opacity: 0.85,
              y: 0,
              duration: 0.6,
              ease: 'power2.out',
              delay: 0.2
            });
          }
        });

        // Phase 1 – rapid photo reel with synchronized camera clicks
        reelPhotos.forEach((photo, i) => {
          tl.to(photo, { opacity: 1, duration: 0.06 }, i * 0.13)
            .add(() => playCameraClickSound(), i * 0.13)
            .to(photo, { opacity: 0, duration: 0.07 }, i * 0.13 + 0.06);
        });
        tl.to(photoReel, { opacity: 0, duration: 0.18, ease: 'power2.in' }, '+=0.04');

        // Phase 2 – PORTFOLIO slams in with heavy mechanical shutter thud
        tl.to(portfolioWord, {
          opacity: 1, scaleY: 1, letterSpacing: '-0.04em',
          duration: 0.85, ease: 'power4.out'
        }, '-=0.05')
        .add(() => playSlamSound(), '-=0.05');

        // Phase 2b – blue shimmer sweep
        tl.to(portfolioShimmer, { opacity: 1, duration: 0.05 })
          .fromTo(portfolioShimmer,
            { x: '-110%' },
            { x: '210%', duration: 0.65, ease: 'power2.inOut',
              onComplete: () => gsap.set(portfolioShimmer, { opacity: 0 })
            }, '-=0.05'
          );

        return tl;
      };

      // ── Trigger handler: plays visual animation immediately ──
      const triggerReel = () => {
        playReelAnimation();
      };

      // ── Trigger on scroll (first time) ──
      ScrollTrigger.create({
        trigger: '#portfolio',
        start: 'top 78%',
        once: true,
        onEnter: () => {
          triggerReel();
        }
      });

      // ── Trigger on click ──
      portfolioWord.addEventListener('click', () => triggerReel());
    }

    // Filmstrip cards staggered reveal
    const cards = document.querySelectorAll('.film-card');
    cards.forEach((card, i) => {
      gsap.to(card, {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        delay: i * 0.07,
        scrollTrigger: {
          trigger: '#portfolio',
          start: 'top 70%',
        },
        onStart: () => card.classList.add('revealed')
      });
    });

    // Hide scroll hint after user scrolls the filmstrip
    const filmstrip = document.getElementById('filmstrip');
    const scrollHint = document.getElementById('scrollHint');
    if (filmstrip && scrollHint) {
      filmstrip.addEventListener('scroll', () => {
        if (filmstrip.scrollLeft > 60) {
          scrollHint.style.opacity = '0';
        }
      }, { passive: true });
    }

    // Drawer toggle
    const moreBtn = document.getElementById('moreBtn');
    const moreProjects = document.getElementById('moreProjects');
    const moreBtnText = document.getElementById('moreBtnText');
    const moreBtnIcon = document.getElementById('moreBtnIcon');

    if (moreBtn && moreProjects && moreBtnText && moreBtnIcon) {
      let isOpen = false;
      moreBtn.addEventListener('click', () => {
        isOpen = !isOpen;
        if (isOpen) {
          moreBtnText.textContent = 'Close Portfolio Grid';
          moreBtnIcon.style.transform = 'rotate(180deg)';
          
          gsap.killTweensOf(moreProjects);
          gsap.fromTo(moreProjects, 
            { height: 0, opacity: 0 },
            {
              height: 'auto',
              opacity: 1,
              duration: 0.8,
              ease: 'power3.out',
              onStart: () => {
                (moreProjects as HTMLElement).style.display = 'block';
                (moreProjects as HTMLElement).style.overflow = 'hidden';
              },
              onComplete: () => {
                (moreProjects as HTMLElement).style.overflow = 'visible';
              }
            }
          );
        } else {
          moreBtnText.textContent = 'View 25 More Projects';
          moreBtnIcon.style.transform = 'rotate(0deg)';
          
          gsap.killTweensOf(moreProjects);
          (moreProjects as HTMLElement).style.overflow = 'hidden';
          
          // Animate collapse (snappy: 0.45s)
          gsap.to(moreProjects, {
            height: 0,
            opacity: 0,
            duration: 0.45,
            ease: 'power3.inOut',
            onComplete: () => {
              (moreProjects as HTMLElement).style.display = 'none';
            }
          });
          
          // Calculate target scroll coordinate (fixed top of moreProjects container - offset for navbar and breathing room)
          const containerRect = moreProjects.getBoundingClientRect();
          const targetScrollTop = window.scrollY + containerRect.top - 180;
          
          // Quick GSAP-driven scroll animation (snappy: 0.4s)
          const scrollObj = { y: window.scrollY };
          gsap.to(scrollObj, {
            y: targetScrollTop,
            duration: 0.4,
            ease: 'power2.out',
            onUpdate: () => {
              window.scrollTo(0, scrollObj.y);
            }
          });
        }
      });
    }
  };

  // Prevent race condition if loaderComplete has already fired
  const preloader = document.getElementById('preloader');
  if (!preloader || preloader.style.display === 'none') {
    initPortfolioAnimations();
  } else {
    window.addEventListener('loaderComplete', initPortfolioAnimations);
  }
</script>
