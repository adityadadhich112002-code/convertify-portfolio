---
---

<section id="portfolio" class="relative bg-canvas overflow-hidden select-none">

  <!-- ─── SECTION HEADER ──────────────────────────────────────────── -->
  <div class="portfolio-header px-6 md:px-16 pt-24 md:pt-32 pb-6 md:pb-8 max-w-7xl mx-auto relative z-10">

    <!-- Eyebrow -->
    <span class="portfolio-eyebrow opacity-0 translate-y-4 flex items-center gap-3 text-[10px] md:text-[11px] font-display font-medium tracking-[0.25em] uppercase text-brand-blue mb-6">
      <span class="w-5 h-[1px] bg-brand-blue/50"></span>
      Our Work
      <span class="w-5 h-[1px] bg-brand-blue/50"></span>
    </span>

    <!-- MOBILE-ONLY: Click indicator helper (very subtle animating arrows, borderless and fast-loading) -->
    <div
      id="portfolio-click-helper"
      class="portfolio-click-helper block sm:hidden opacity-80 flex items-center justify-center gap-2 mb-4 select-none pointer-events-none transition-opacity duration-300"
    >
      <!-- Left Arrow -->
      <svg class="w-3 h-3 text-brand-blue animate-bounce shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
      <span class="text-[9px] md:text-[10px] font-sans font-medium tracking-[0.25em] text-white/45 uppercase">Click on this</span>
      <!-- Right Arrow -->
      <svg class="w-3 h-3 text-brand-blue animate-bounce shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </div>

    <!-- MOBILE-ONLY: Photo reel → PORTFOLIO reveal -->
    <div
      id="portfolio-word-wrap"
      class="portfolio-word-wrap block sm:hidden w-screen relative left-1/2 -translate-x-1/2 overflow-hidden mt-2 mb-4"
      style="height: 22vw;"
      aria-hidden="true"
    >
      <!-- Photo reel: images flash rapidly before PORTFOLIO appears -->
      <div id="portfolio-photo-reel" class="absolute inset-0 z-10">
        <img src="/assets/whatiff-preview.png"        class="reel-photo absolute inset-0 w-full h-full object-cover object-top opacity-0" alt="" />
        <img src="/assets/vegasports-preview.png"     class="reel-photo absolute inset-0 w-full h-full object-cover object-top opacity-0" alt="" />
        <img src="/assets/whitehusk-preview.png"      class="reel-photo absolute inset-0 w-full h-full object-cover object-top opacity-0" alt="" />
        <img src="/assets/wheelsco-preview.png"       class="reel-photo absolute inset-0 w-full h-full object-cover object-top opacity-0" alt="" />
        <img src="/assets/hype-preview.png"           class="reel-photo absolute inset-0 w-full h-full object-cover object-top opacity-0" alt="" />
        <img src="/assets/pcac-preview.png"           class="reel-photo absolute inset-0 w-full h-full object-cover object-top opacity-0" alt="" />
        <!-- dark tint so flashes feel cinematic -->
        <div class="absolute inset-0 bg-black/50"></div>
      </div>

      <!-- PORTFOLIO text – brand blue, starts invisible -->
      <div
        id="portfolio-word"
        class="portfolio-word absolute inset-0 z-20 font-display font-black uppercase text-center leading-none select-none flex items-center justify-center cursor-pointer"
        title="Click to replay"
        style="font-size: 17.5vw; letter-spacing: 0.55em; opacity: 0; transform: scaleY(0.82); transform-origin: bottom center; color: var(--color-brand-blue, #0099ff);"
      >PORTFOLIO</div>

      <!-- Shimmer sweep overlay -->
      <div
        id="portfolio-shimmer"
        class="absolute inset-0 pointer-events-none z-30"
        style="background: linear-gradient(105deg, transparent 25%, rgba(0,153,255,0.22) 50%, transparent 75%); transform: translateX(-110%); opacity: 0;"
      ></div>
    </div>

    <!-- Hero-style heading -->
    <div class="portfolio-heading opacity-0 translate-y-8 max-w-[860px]">
      <h2 class="text-[40px] sm:text-display-xl text-white font-bold leading-[0.9] tracking-[-0.05em]">
        <span class="block">Don't Take</span>
        <span class="block">Our Word For It.</span>
        <span class="block mt-2">
          <em class="font-script not-italic text-brand-blue text-[1.08em]">Judge The Work.</em>
        </span>
      </h2>
    </div>

    <!-- Stats row -->
    <div class="portfolio-stats opacity-0 translate-y-6 flex items-center gap-8 md:gap-14 mt-8 md:mt-10">
      <div class="flex flex-col gap-1">
        <span class="font-display text-[36px] md:text-[48px] font-bold text-white leading-none tracking-tight">437+</span>
        <span class="text-[9px] md:text-[10px] tracking-[0.12em] font-medium text-white/35 uppercase">Websites Delivered</span>
      </div>
      <div class="w-[1px] h-10 bg-white/10"></div>
      <div class="flex flex-col gap-1">
        <span class="font-display text-[36px] md:text-[48px] font-bold text-white leading-none tracking-tight">12+</span>
        <span class="text-[9px] md:text-[10px] tracking-[0.12em] font-medium text-white/35 uppercase">Agencies Partnered</span>
      </div>
      <div class="hidden md:flex flex-col gap-1 ml-auto">
        <p class="text-body-sm text-white/40 max-w-[280px] text-right leading-relaxed">Ecommerce · SaaS · Luxury<br>Personal Brand · Healthcare</p>
      </div>
    </div>

  </div>

  <!-- ─── FILMSTRIP SCROLL TRACK ───────────────────────────────────── -->
  <!-- Desktop: horizontal snap scroll / Mobile: vertical stack -->
  <div class="portfolio-filmstrip-wrap relative">

    <!-- Gradient edge fades (desktop) -->
    <div class="hidden md:block absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-canvas to-transparent z-20 pointer-events-none"></div>
    <div class="hidden md:block absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-canvas to-transparent z-20 pointer-events-none"></div>

    <!-- Scroll track -->
    <div
      id="filmstrip"
      class="portfolio-filmstrip flex flex-col md:flex-row md:overflow-x-auto gap-4 md:gap-5 px-6 md:px-24 pb-10 md:pb-14 md:snap-x md:snap-mandatory scroll-smooth"
      style="scrollbar-width: none; -ms-overflow-style: none;"
    >

      <!-- ── Card 1: WhatIff (WIDE hero card) ── -->
      <a
        href="https://whatiff.in/" target="_blank" rel="noopener"
        class="film-card group relative flex-shrink-0 w-full md:w-[700px] lg:w-[820px] rounded-[24px] overflow-hidden border border-hairline bg-surface-1 md:snap-start"
        style="aspect-ratio: 16/10; min-height: 320px;"
        data-index="0"
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src="/assets/whatiff-preview.png" alt="WhatIff" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out group-hover:scale-[1.06]" loading="lazy" />
          <!-- Cinematic overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-black/10"></div>
          <!-- Blue glow on hover -->
          <div class="absolute inset-0 bg-brand-blue/0 group-hover:bg-brand-blue/5 transition-colors duration-700"></div>
        </div>

        <!-- Top meta -->
        <div class="absolute top-5 left-5 right-5 z-10 flex items-center justify-between">
          <span class="px-3 py-1.5 bg-black/70 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold tracking-wider uppercase text-white">SaaS</span>
          <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-500 inline-flex items-center gap-1.5 text-[11px] text-white/60 font-medium">
            Visit ↗
          </span>
        </div>

        <!-- Bottom info -->
        <div class="absolute inset-x-0 bottom-0 z-10 p-6 md:p-8">
          <p class="text-[10px] font-display tracking-[0.18em] uppercase text-brand-blue/80 mb-2 font-medium">Fintech Platform</p>
          <h3 class="text-display-md text-white font-bold leading-tight tracking-tight mb-3 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">WhatIff</h3>
          <p class="text-body-sm text-white/60 max-w-[380px] opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500 delay-75">Privacy-first fintech UX built to convert visitors into active planners.</p>
        </div>

        <!-- Card index -->
        <div class="absolute top-5 right-5 opacity-0 group-hover:opacity-0 w-7 h-7 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[10px] font-mono text-white/30">01</div>
      </a>

      <!-- ── Card 2: Vega Sports ── -->
      <a
        href="https://vegasports.in/" target="_blank" rel="noopener"
        class="film-card group relative flex-shrink-0 w-full md:w-[480px] lg:w-[560px] rounded-[24px] overflow-hidden border border-hairline bg-surface-1 md:snap-start"
        style="aspect-ratio: 16/10; min-height: 320px;"
        data-index="1"
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src="/assets/vegasports-preview.png" alt="Vega Sports" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out group-hover:scale-[1.06]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-black/10"></div>
        </div>
        <div class="absolute top-5 left-5 z-10">
          <span class="px-3 py-1.5 bg-black/70 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold tracking-wider uppercase text-white">Sports</span>
        </div>
        <div class="absolute inset-x-0 bottom-0 z-10 p-6">
          <p class="text-[10px] font-display tracking-[0.18em] uppercase text-brand-blue/80 mb-2 font-medium">Sports Booking Platform</p>
          <h3 class="text-[22px] md:text-[26px] text-white font-bold leading-tight tracking-tight mb-2 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">Vega Sports</h3>
          <p class="text-body-sm text-white/60 max-w-[320px] opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500 delay-75">Real-time booking flow turning intent into confirmed reservations.</p>
        </div>
      </a>

      <!-- ── Card 3: White Husk ── -->
      <a
        href="https://www.whitehusk.com/" target="_blank" rel="noopener"
        class="film-card group relative flex-shrink-0 w-full md:w-[480px] lg:w-[560px] rounded-[24px] overflow-hidden border border-hairline bg-surface-1 md:snap-start"
        style="aspect-ratio: 16/10; min-height: 320px;"
        data-index="2"
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src="/assets/whitehusk-preview.png" alt="White Husk" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out group-hover:scale-[1.06]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-black/10"></div>
        </div>
        <div class="absolute top-5 left-5 z-10">
          <span class="px-3 py-1.5 bg-black/70 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold tracking-wider uppercase text-white">Ecommerce</span>
        </div>
        <div class="absolute inset-x-0 bottom-0 z-10 p-6">
          <p class="text-[10px] font-display tracking-[0.18em] uppercase text-brand-blue/80 mb-2 font-medium">Streetwear Brand</p>
          <h3 class="text-[22px] md:text-[26px] text-white font-bold leading-tight tracking-tight mb-2 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">White Husk</h3>
          <p class="text-body-sm text-white/60 max-w-[320px] opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500 delay-75">Bold storefront engineered to stop the scroll and drive purchases.</p>
        </div>
      </a>

      <!-- ── Card 4: The Wheels Co (WIDE) ── -->
      <a
        href="https://thewheelsco.com/" target="_blank" rel="noopener"
        class="film-card group relative flex-shrink-0 w-full md:w-[700px] lg:w-[820px] rounded-[24px] overflow-hidden border border-hairline bg-surface-1 md:snap-start"
        style="aspect-ratio: 16/10; min-height: 320px;"
        data-index="3"
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src="/assets/wheelsco-preview.png" alt="The Wheels Co" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out group-hover:scale-[1.06]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-black/10"></div>
          <div class="absolute inset-0 bg-brand-blue/0 group-hover:bg-brand-blue/5 transition-colors duration-700"></div>
        </div>
        <div class="absolute top-5 left-5 right-5 z-10 flex items-center justify-between">
          <span class="px-3 py-1.5 bg-black/70 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold tracking-wider uppercase text-white">Ecommerce</span>
          <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-500 inline-flex items-center gap-1.5 text-[11px] text-white/60 font-medium">Visit ↗</span>
        </div>
        <div class="absolute inset-x-0 bottom-0 z-10 p-6 md:p-8">
          <p class="text-[10px] font-display tracking-[0.18em] uppercase text-brand-blue/80 mb-2 font-medium">Automotive Lifestyle</p>
          <h3 class="text-display-md text-white font-bold leading-tight tracking-tight mb-3 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">The Wheels Co.</h3>
          <p class="text-body-sm text-white/60 max-w-[380px] opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500 delay-75">Playful ecommerce experience tuned to convert family buyers at scale.</p>
        </div>
      </a>

      <!-- ── Card 5: FeetIt Insoles ── -->
      <a
        href="https://feetitinsoles.com/" target="_blank" rel="noopener"
        class="film-card group relative flex-shrink-0 w-full md:w-[480px] lg:w-[560px] rounded-[24px] overflow-hidden border border-hairline bg-surface-1 md:snap-start"
        style="aspect-ratio: 16/10; min-height: 320px;"
        data-index="4"
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src="/assets/feetit-preview.png" alt="FeetIt Insoles" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out group-hover:scale-[1.06]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-black/10"></div>
        </div>
        <div class="absolute top-5 left-5 z-10">
          <span class="px-3 py-1.5 bg-black/70 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold tracking-wider uppercase text-white">Healthcare</span>
        </div>
        <div class="absolute inset-x-0 bottom-0 z-10 p-6">
          <p class="text-[10px] font-display tracking-[0.18em] uppercase text-brand-blue/80 mb-2 font-medium">Health & Wellness</p>
          <h3 class="text-[22px] md:text-[26px] text-white font-bold leading-tight tracking-tight mb-2 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">FeetIt Insoles</h3>
          <p class="text-body-sm text-white/60 max-w-[320px] opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500 delay-75">Healthcare platform structured to turn appointment intent into booked consults.</p>
        </div>
      </a>

      <!-- ── Card 6: Hype Jewellery ── -->
      <a
        href="https://hypejewellery.in/" target="_blank" rel="noopener"
        class="film-card group relative flex-shrink-0 w-full md:w-[380px] lg:w-[440px] rounded-[24px] overflow-hidden border border-hairline bg-surface-1 md:snap-start"
        style="aspect-ratio: 4/5; min-height: 320px;"
        data-index="5"
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src="/assets/hype-preview.png" alt="Hype Jewellery" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out group-hover:scale-[1.06]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/30 to-transparent"></div>
        </div>
        <div class="absolute top-5 left-5 z-10">
          <span class="px-3 py-1.5 bg-black/70 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold tracking-wider uppercase text-white">Luxury</span>
        </div>
        <div class="absolute inset-x-0 bottom-0 z-10 p-6">
          <p class="text-[10px] font-display tracking-[0.18em] uppercase text-brand-blue/80 mb-1.5 font-medium">Luxury Jewellery</p>
          <h3 class="text-[20px] text-white font-bold leading-tight tracking-tight transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">Hype Jewellery</h3>
        </div>
      </a>

      <!-- ── Card 7: Persian Carpet Art Centre (WIDE) ── -->
      <a
        href="https://pcac.com.au/" target="_blank" rel="noopener"
        class="film-card group relative flex-shrink-0 w-full md:w-[700px] lg:w-[820px] rounded-[24px] overflow-hidden border border-hairline bg-surface-1 md:snap-start"
        style="aspect-ratio: 16/10; min-height: 320px;"
        data-index="6"
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src="/assets/pcac-preview.png" alt="Persian Carpet Art Centre" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out group-hover:scale-[1.06]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-black/10"></div>
          <div class="absolute inset-0 bg-brand-blue/0 group-hover:bg-brand-blue/5 transition-colors duration-700"></div>
        </div>
        <div class="absolute top-5 left-5 right-5 z-10 flex items-center justify-between">
          <span class="px-3 py-1.5 bg-black/70 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold tracking-wider uppercase text-white">Luxury</span>
          <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-500 inline-flex items-center gap-1.5 text-[11px] text-white/60 font-medium">Visit ↗</span>
        </div>
        <div class="absolute inset-x-0 bottom-0 z-10 p-6 md:p-8">
          <p class="text-[10px] font-display tracking-[0.18em] uppercase text-brand-blue/80 mb-2 font-medium">Luxury Home Decor · Australia</p>
          <h3 class="text-display-md text-white font-bold leading-tight tracking-tight mb-3 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">Persian Carpet Art Centre</h3>
          <p class="text-body-sm text-white/60 max-w-[380px] opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500 delay-75">Gallery experience that positions six-figure purchases with authority.</p>
        </div>
      </a>

      <!-- ── Card 8: Chashma ── -->
      <a
        href="https://chashma.com/" target="_blank" rel="noopener"
        class="film-card group relative flex-shrink-0 w-full md:w-[480px] lg:w-[560px] rounded-[24px] overflow-hidden border border-hairline bg-surface-1 md:snap-start"
        style="aspect-ratio: 16/10; min-height: 320px;"
        data-index="7"
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src="/assets/chashma-preview.png" alt="Chashma" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out group-hover:scale-[1.06]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-black/10"></div>
        </div>
        <div class="absolute top-5 left-5 z-10">
          <span class="px-3 py-1.5 bg-black/70 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold tracking-wider uppercase text-white">Ecommerce</span>
        </div>
        <div class="absolute inset-x-0 bottom-0 z-10 p-6">
          <p class="text-[10px] font-display tracking-[0.18em] uppercase text-brand-blue/80 mb-2 font-medium">Eyewear Brand</p>
          <h3 class="text-[22px] md:text-[26px] text-white font-bold leading-tight tracking-tight mb-2 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">Chashma</h3>
          <p class="text-body-sm text-white/60 max-w-[320px] opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-500 delay-75">Curated eyewear experience engineered to shorten the research-to-buy loop.</p>
        </div>
      </a>

      <!-- ── Card 9: Anand Sweets ── -->
      <a
        href="https://www.anandsweets.in/" target="_blank" rel="noopener"
        class="film-card group relative flex-shrink-0 w-full md:w-[380px] lg:w-[440px] rounded-[24px] overflow-hidden border border-hairline bg-surface-1 md:snap-start"
        style="aspect-ratio: 4/5; min-height: 320px;"
        data-index="8"
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src="/assets/anandsweets-preview.png" alt="Anand Sweets" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1200ms] ease-out group-hover:scale-[1.06]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/30 to-transparent"></div>
        </div>
        <div class="absolute top-5 left-5 z-10">
          <span class="px-3 py-1.5 bg-black/70 backdrop-blur-md border border-white/20 rounded-full text-[10px] font-bold tracking-wider uppercase text-white">Ecommerce</span>
        </div>
        <div class="absolute inset-x-0 bottom-0 z-10 p-6">
          <p class="text-[10px] font-display tracking-[0.18em] uppercase text-brand-blue/80 mb-1.5 font-medium">Premium Food Brand</p>
          <h3 class="text-[20px] text-white font-bold leading-tight tracking-tight transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">Anand Sweets</h3>
        </div>
      </a>

    </div><!-- /filmstrip -->

    <!-- Scroll hint (desktop) -->
    <div id="scrollHint" class="hidden md:flex absolute bottom-6 left-1/2 -translate-x-1/2 items-center gap-2 text-[10px] tracking-[0.15em] uppercase text-white/25 font-medium pointer-events-none z-30 transition-opacity duration-500">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="opacity-60">
        <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Scroll to explore
    </div>
  </div>

  <!-- ─── VIEW ALL DRAWER ──────────────────────────────────────────── -->
  <div class="px-6 md:px-16 pb-24 md:pb-32 max-w-7xl mx-auto relative z-10">

    <!-- Collapsible drawer -->
    <div id="moreProjects" class="h-0 opacity-0 overflow-hidden" style="display: none;">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 pt-4 pb-6" id="moreGrid">
        {[
          { name: "Shop Selectives", ind: "Premium Streetwear", tag: "Luxury", href: "https://www.shopselectives.com/", img: "selectives-preview.png" },
          { name: "Shreeka", ind: "Luxury Fashion", tag: "Luxury", href: "https://www.shreeka.in/", img: "shreeka-preview.png" },
          { name: "Panihari Vastra", ind: "Ethnic Fashion", tag: "Ecommerce", href: "https://paniharivastra.com/", img: "paniharivastra-preview.png" },
          { name: "Kryjer", ind: "Activewear", tag: "Ecommerce", href: "https://kryjer.com/", img: "kryjer-preview.png" },
          { name: "Jivika Pure", ind: "Organic Food", tag: "Ecommerce", href: "https://www.jivikapure.food/", img: "jivikapure-preview.png" },
          { name: "Chic Therapy", ind: "Lifestyle", tag: "Ecommerce", href: "https://chictherapy.com/", img: "chictherapy-preview.png" },
          { name: "Glyters", ind: "Jewellery", tag: "Luxury", href: "https://www.glyters.com/", img: "glyters-preview.png" },
