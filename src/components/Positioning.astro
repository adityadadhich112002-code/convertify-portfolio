  }

  .pos-mob-scroll::-moz-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.4);
    border-radius: 3px;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { TextPlugin } from 'gsap/TextPlugin';
  gsap.registerPlugin(ScrollTrigger, TextPlugin);

  const initPositioningAnimations = () => {
    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    const entranceStart = 'top 95%';
    const innerStart = 'top 95%';

    // ── Entrance Animations ──
    const headerTl = gsap.timeline({
      scrollTrigger: {
        trigger: '#positioning',
        start: entranceStart
      }
    });

    headerTl.to('#pos-eyebrow', { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' })
      .to('.pos-word', {
        opacity: 1,
        y: 0,
        stagger: 0.06,
        duration: 0.7,
        ease: 'power3.out'
      }, '-=0.55')
      .to('#pos-scribble-path-1', {
        strokeDashoffset: 0,
        duration: 0.8,
        ease: 'power2.out'
      }, '-=0.35')
      .to('#pos-scribble-path-2', {
        strokeDashoffset: 0,
        duration: 0.8,
        ease: 'power2.out'
      }, '-=0.65')
      .to('.pos-highlight', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'back.out(1.5)'
      }, '-=0.8');

    gsap.to('.positioning-grid', {
      opacity: 1,
      y: 0,
      duration: 0.9,
      ease: 'power3.out',
      delay: 0.35,
      scrollTrigger: { trigger: '#positioning', start: entranceStart },
      onComplete: () => {
        switchSandbox(1);
        startAutoplay();
      }
    });

    // ── Interactive Sandbox Switching Logic ──
    const desktopButtons = document.querySelectorAll('.pos-btn');
    const mobileButtons = document.querySelectorAll('.pos-btn-mob');
    const cards = document.querySelectorAll('.pos-sandbox-card');
    const bgGlow = document.getElementById('pos-bg-glow');
    const consoleGlow = document.getElementById('pos-console-glow');
    const modeLabel = document.getElementById('pos-console-mode');
    
    let activeIndex = 0;
    let timerInterval: any = null;
    let autoPlayTimer: any = null;

    // Synthesize UI feedback click sounds (Premium tactile tick/pop)
    let audioCtx: AudioContext | null = null;
    const playClickSound = () => {
      try {
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
        }
        if (audioCtx.state === 'suspended') {
          audioCtx.resume();
        }
        
        const now = audioCtx.currentTime;
        
        // 1. Softer base pop (sine wave, quick pitch drop)
        const osc1 = audioCtx.createOscillator();
        const gain1 = audioCtx.createGain();
        osc1.type = 'sine';
        osc1.connect(gain1);
        gain1.connect(audioCtx.destination);
        
        osc1.frequency.setValueAtTime(320, now);
        osc1.frequency.exponentialRampToValueAtTime(80, now + 0.05);
        
        gain1.gain.setValueAtTime(0.05, now);
        gain1.gain.exponentialRampToValueAtTime(0.001, now + 0.05);
        
        osc1.start(now);
        osc1.stop(now + 0.06);
        
        // 2. High-frequency crisp transient (subtle tick)
        const osc2 = audioCtx.createOscillator();
        const gain2 = audioCtx.createGain();
        osc2.type = 'sine';
        osc2.connect(gain2);
        gain2.connect(audioCtx.destination);
        
        osc2.frequency.setValueAtTime(1600, now);
        osc2.frequency.exponentialRampToValueAtTime(600, now + 0.012);
        
        gain2.gain.setValueAtTime(0.015, now);
        gain2.gain.exponentialRampToValueAtTime(0.001, now + 0.012);
        
        osc2.start(now);
        osc2.stop(now + 0.02);
      } catch (e) {
        // Suppress audio policy warnings silently
      }
    };

    // Color theme configuration per index
    const colorThemes = [
      { border: 'rgba(16, 185, 129, 0.3)', glow: 'from-emerald-500/10', mode: 'SSL VERIFY', bg: 'rgba(16,185,129,0.04)' },
      { border: 'rgba(20, 0, 255, 0.3)', glow: 'from-brand-blue/10', mode: 'COGNITIVE FAQ', bg: 'rgba(20,0,255,0.04)' },
      { border: 'rgba(168, 85, 247, 0.3)', glow: 'from-violet-500/10', mode: 'PAYMENT FLOW', bg: 'rgba(168,85,247,0.04)' },
      { border: 'rgba(245, 158, 11, 0.3)', glow: 'from-amber-500/10', mode: 'SCARCITY TIMER', bg: 'rgba(245,158,11,0.04)' },
      { border: 'rgba(6, 182, 212, 0.3)', glow: 'from-cyan-500/10', mode: 'RISK REVERSAL', bg: 'rgba(6,182,212,0.04)' },
      { border: 'rgba(236, 72, 153, 0.3)', glow: 'from-pink-500/10', mode: 'CTA EXP burst', bg: 'rgba(236,72,153,0.04)' },
      { border: 'rgba(59, 130, 246, 0.3)', glow: 'from-blue-500/10', mode: 'SPEED SWEEP', bg: 'rgba(59,130,246,0.04)' }
    ];

    // Dynamic laser indicator line update
    const updateLaserLine = () => {
      const activeBtn = document.querySelector('.pos-btn.pos-active') as HTMLElement;
      const laser = document.getElementById('pos-laser-line');
      if (activeBtn && laser && activeBtn.offsetParent !== null) {
        laser.style.top = `${activeBtn.offsetTop}px`;
        laser.style.height = `${activeBtn.offsetHeight}px`;
      }
    };

    // Geolocation simulator mock
    const fetchGeoIPMock = () => {
      const locationText = document.getElementById('pos-visitor-location');
      if (locationText) {
        const cities = ['New Delhi, IN', 'London, UK', 'New York, US', 'Mumbai, IN', 'California, US'];
        let count = 0;
        locationText.textContent = `Connected: ${cities[0]}`;
        setInterval(() => {
          count = (count + 1) % cities.length;
          locationText.textContent = `Connected: ${cities[count]}`;
        }, 8000);
      }
    };
    fetchGeoIPMock();

    // ── Internal Sandbox Animation Triggers ──
    
    // Panel 0: Trust score circle gauge sweep & count up (Apple Premium Easing)
    const runTrustAnimation = () => {
      const circle = document.getElementById('trust-gauge-circle');
      const counter = document.getElementById('trust-counter');
      const check1 = document.getElementById('trust-check-1');
      const check2 = document.getElementById('trust-check-2');
      const check2Icon = document.getElementById('trust-check-2-icon');
      
      if (circle && counter) {
        gsap.killTweensOf([circle, counter, check1, check2, check2Icon]);
        
        // Reset
        gsap.set(circle, { strokeDashoffset: 251 });
        counter.textContent = '0%';
        if (check1 && check2 && check2Icon) {
          gsap.set([check1, check2], { opacity: 0.5, scale: 0.98 });
          check2Icon.classList.remove('text-emerald-400');
          check2Icon.classList.add('text-white/40');
        }

        // Animate stroke sweep with Apple power4.out
        gsap.to(circle, {
          strokeDashoffset: 5, // ~98% of 251
          duration: 1.8,
          ease: 'power4.out'
        });

        // Animate counter text
        const obj = { val: 0 };
        gsap.to(obj, {
          val: 98,
          duration: 1.6,
          ease: 'power3.out',
          onUpdate: () => {
            counter.textContent = Math.round(obj.val) + '%';
          },
          onComplete: () => {
            if (check1 && check2 && check2Icon) {
              gsap.timeline()
                .to(check1, { opacity: 1, scale: 1, duration: 0.35, ease: 'back.out(1.5)' })
                .to(check2, { opacity: 1, scale: 1, duration: 0.35, ease: 'back.out(1.5)' }, '-=0.18')
                .call(() => {
                  check2Icon.classList.remove('text-white/40');
                  check2Icon.classList.add('text-emerald-400');
                });
            }
          }
        });
      }
    };

    // Panel 1: Q&A Question Typing & Answer Reveal
    const runQAAnimation = () => {
      const q1 = document.getElementById('qa-msg-q1');
      const a1 = document.getElementById('qa-msg-a1');
      const qText = document.getElementById('qa-q1-text');
      
      if (q1 && a1 && qText) {
        gsap.killTweensOf([q1, a1, qText]);
        
        // Reset
        qText.textContent = '';
        gsap.set([q1, a1], { opacity: 0, y: 15 });

        const questionStr = "Is there a money back guarantee?";
        const tl = gsap.timeline();
        
        tl.to(q1, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' });

        // Type question letter-by-letter
        questionStr.split('').forEach((char, i) => {
          tl.to(qText, {
            text: questionStr.substring(0, i + 1),
            duration: 0.04,
            ease: 'none'
          }, (i * 0.04) + 0.4);
        });

        // Reveal answer bubble
        tl.to(a1, {
          opacity: 1,
          y: 0,
          duration: 0.55,
          ease: 'back.out(1.15)'
        }, `+=${0.1}`);
      }
    };

    // Panel 2: Credit Card slide friction pay + Receipt Output
    const runCardAnimation = () => {
      const card = document.getElementById('pos-credit-card');
      const success = document.getElementById('card-success-glow');
      const receipt = document.getElementById('pos-receipt');
      if (card && success && receipt) {
        gsap.killTweensOf([card, success, receipt]);

        // Reset
        gsap.set(card, { transform: 'translateY(120px) scale(0.9)', opacity: 0 });
        gsap.set(success, { opacity: 0 });
        gsap.set(receipt, { opacity: 0, transform: 'translateY(0px)' });

        const tl = gsap.timeline();
        
        // Slide card up to slots
        tl.to(card, {
          opacity: 1,
          transform: 'translateY(24px) scale(1)',
          duration: 0.7,
          ease: 'power3.out'
        })
        // Push card slightly into slot
        .to(card, {
          transform: 'translateY(4px) scale(1)',
          duration: 0.4,
          ease: 'sine.inOut'
        })
        // Trigger verification glow overlay
        .to(success, {
          opacity: 1,
          duration: 0.3
        }, '+=0.1')
        // Printout receipt (slides down in front of card)
        .to(receipt, {
          opacity: 1,
          transform: 'translateY(100px)',
          duration: 0.8,
          ease: 'power2.out'
        }, '+=0.15');
      }
    };

    // Panel 3: Countdown Timer ticking down + progress bar decrease
    const runTimerAnimation = () => {
      const minEl = document.getElementById('pos-timer-min');
      const secEl = document.getElementById('pos-timer-sec');
      const bar = document.getElementById('scarcity-bar');
      const slotLabel = document.getElementById('scarcity-slots');
      
      if (minEl && secEl && bar && slotLabel) {
        clearInterval(timerInterval);
        
        let min = 9;
        let sec = 59;
        minEl.textContent = '09';
        secEl.textContent = '59';
        
        gsap.set(bar, { width: '80%' });
        slotLabel.textContent = '2 Slots Left';

        // Animate timer tick-down
        timerInterval = setInterval(() => {
          sec--;
          if (sec < 0) {
            sec = 59;
            min--;
          }
          if (min < 0) {
            clearInterval(timerInterval);
            return;
          }
          minEl.textContent = min < 10 ? '0' + min : '' + min;
          secEl.textContent = sec < 10 ? '0' + sec : '' + sec;
          
          // Micro-tick progress bar decrement
          const totalSecs = (min * 60) + sec;
          const percentage = (totalSecs / 600) * 80;
          bar.style.width = `${percentage}%`;
        }, 1000);
      }
    };

    // Panel 4: Vault Padlock locks & text badge rotates
    const runLockAnimation = () => {
      const shackle = document.getElementById('lock-shackle');
      const lockBody = document.getElementById('pos-padlock');
      const rotator = document.getElementById('pos-rotator-badge');
      const w1 = document.getElementById('lock-wave-1');
      const w2 = document.getElementById('lock-wave-2');
      
      if (shackle && lockBody && rotator && w1 && w2) {
        gsap.killTweensOf([shackle, lockBody, rotator, w1, w2]);

        // Reset
        gsap.set(shackle, { transform: 'translateY(-14px)' }); // shackle open state
        gsap.set(lockBody, { scale: 1 });
        gsap.set([w1, w2], { scale: 0.5, opacity: 0 });

        // Spin certificate seal badge
        gsap.to(rotator, {
          rotation: 360,
          duration: 20,
          ease: 'none',
          repeat: -1
        });

        // Snap closed timeline
        const tl = gsap.timeline();
        tl.to(shackle, {
          transform: 'translateY(0)',
          duration: 0.35,
          ease: 'power3.in',
          delay: 0.3
        })
        // Lock body impact scaling
        .to(lockBody, {
          scaleY: 0.94,
          scaleX: 1.04,
          duration: 0.08,
          ease: 'sine.inOut'
        })
        .to(lockBody, {
          scale: 1,
          duration: 0.12,
          ease: 'sine.out'
        })
        // Radiate glowing waves
        .fromTo([w1, w2],
          { scale: 0.5, opacity: 0 },
          {
            scale: 1.3,
            opacity: 0.8,
            stagger: 0.18,
            duration: 0.85,
            ease: 'power2.out',
            onComplete: () => {
              gsap.set([w1, w2], { opacity: 0 });
            }
          },
          '-=0.08'
        );
      }
    };

    // Panel 5: Button glare, simulated click + custom particle burst
    const runCTAAnimation = () => {
      const btn = document.getElementById('pos-action-btn');
      const glare = document.getElementById('pos-btn-glare');
      const cursor = document.getElementById('pos-mock-cursor');
      if (btn && glare && cursor) {
        gsap.killTweensOf([btn, glare, cursor]);

        // Reset
        gsap.set(glare, { x: '-100%' });
        gsap.set(cursor, { transform: 'translate(120px, 90px)' });

        const tl = gsap.timeline();

        // 1. Move mock cursor to click center
        tl.to(cursor, {
          transform: 'translate(25px, 20px)',
          duration: 1.0,
          ease: 'power3.out',
          delay: 0.3
        })
        // 2. Press CTA button down
        .to(btn, {
          scale: 0.94,
          duration: 0.12,
          ease: 'power2.inOut',
          onComplete: () => {
            // Trigger particle burst at the exact button center!
            const x = btn.offsetLeft + btn.offsetWidth / 2;
            const y = btn.offsetTop + btn.offsetHeight / 2;
            triggerBurst(x, y, btn.parentElement!);
          }
        })
        // 3. Release button & sweep glare shine
        .to(btn, {
          scale: 1,
          duration: 0.15,
          ease: 'power2.out'
        })
        .fromTo(glare, 
          { x: '-100%' },
          { x: '180%', duration: 0.7, ease: 'power2.inOut' },
          '-=0.05'
        )
        // 4. Move cursor out of view
        .to(cursor, {
          transform: 'translate(130px, 110px)',
          duration: 0.7,
          ease: 'power2.in'
        }, '+=0.2');
      }
    };

    // Spawn 20+ glowing circles radiating from click point
    const triggerBurst = (x: number, y: number, container: HTMLElement) => {
      const colors = ['#1400ff', '#d44df0', '#6a4cf5', '#ff7a3d', '#ff5577', '#10b981'];
      for (let i = 0; i < 24; i++) {
        const p = document.createElement('div');
        p.className = 'absolute w-2.5 h-2.5 rounded-full pointer-events-none z-30';
        const color = colors[Math.floor(Math.random() * colors.length)];
        p.style.backgroundColor = color;
        p.style.boxShadow = `0 0 10px ${color}`;
        p.style.left = `${x}px`;
        p.style.top = `${y}px`;
        container.appendChild(p);

        const fontColor = color;
        const angle = Math.random() * Math.PI * 2;
        const velocity = 40 + Math.random() * 100;
        const destX = Math.cos(angle) * velocity;
        const destY = Math.sin(angle) * velocity;

        gsap.to(p, {
          x: destX,
          y: destY,
          opacity: 0,
          scale: 0.1,
          duration: 0.75 + Math.random() * 0.4,
          ease: 'power2.out',
          onComplete: () => p.remove()
        });
      }
    };

    // Panel 6: Apple-like speed sweep (Simple and Premium)
    const runSpeedAnimation = () => {
      const circle = document.getElementById('speed-gauge-circle');
      const counter = document.getElementById('speed-counter');
      if (circle && counter) {
        gsap.killTweensOf([circle, counter]);
        
        // Reset
        gsap.set(circle, { strokeDashoffset: 264 });
        counter.textContent = '0';

        // Animate stroke sweep with Apple-like power4.out ease
        gsap.to(circle, {
          strokeDashoffset: 0,
          duration: 1.8,
          ease: 'power4.out'
        });

        // Animate speed counter text to 100
        const obj = { val: 0 };
        gsap.to(obj, {
          val: 100,
          duration: 1.5,
          ease: 'power3.out',
          onUpdate: () => {
            counter.textContent = String(Math.round(obj.val));
          }
        });
      }
    };

    // Trigger correct sub-animations depending on the active slide index
    const triggerInnerAnimation = (idx: number) => {
      if (idx === 0) runTrustAnimation();
      else if (idx === 1) runQAAnimation();
      else if (idx === 2) runCardAnimation();
      else if (idx === 3) runTimerAnimation();
      else if (idx === 4) runLockAnimation();
      else if (idx === 5) runCTAAnimation();
      else if (idx === 6) runSpeedAnimation();
    };

    // ── Click and selector controls for Pillars ──
    const switchSandbox = (idx: number) => {
      if (activeIndex === idx) return;

      // Get color tokens
      const activeTheme = colorThemes[idx];

      // 1. Update active button classes for desktop
      desktopButtons.forEach((btn, i) => {
        const bullet = btn.querySelector('span.w-3\\.5');
        const tag = btn.querySelector('span.text-\\[8px\\]');
        const titleText = btn.querySelector('span.text-\\[13px\\]');
        const descText = btn.querySelector('span.font-normal');
        
        if (i === idx) {
          btn.classList.add('pos-active', 'bg-surface-1', 'border-white/30', 'shadow-[0_8px_24px_rgba(20,0,255,0.1)]', 'translate-x-1.5');
          btn.classList.remove('bg-surface-1/40', 'border-white/10', 'hover:border-white/20', 'hover:bg-white/[0.02]');
          if (bullet) {
            bullet.classList.add('bg-brand-blue', 'border-brand-blue', 'shadow-[0_0_8px_rgba(20,0,255,0.7)]');
            bullet.classList.remove('bg-[#0f0f13]', 'border-white/10');
          }
          if (tag) {
            tag.classList.add('text-white', 'bg-brand-blue/30', 'border-brand-blue/30');
            tag.classList.remove('text-white/40', 'bg-white/5', 'border-white/5');
          }
          if (titleText) {
            titleText.classList.add('text-white');
            titleText.classList.remove('text-white/60');
          }
          if (descText) {
            descText.classList.add('text-white/45');
            descText.classList.remove('text-white/30');
          }
        } else {
          btn.classList.remove('pos-active', 'bg-surface-1', 'border-white/30', 'shadow-[0_8px_24px_rgba(20,0,255,0.1)]', 'translate-x-1.5');
          btn.classList.add('bg-surface-1/40', 'border-white/10', 'hover:border-white/20', 'hover:bg-white/[0.02]');
          if (bullet) {
            bullet.classList.remove('bg-brand-blue', 'border-brand-blue', 'shadow-[0_0_8px_rgba(20,0,255,0.7)]');
            bullet.classList.add('bg-[#0f0f13]', 'border-white/10');
          }
          if (tag) {
            tag.classList.remove('text-white', 'bg-brand-blue/30', 'border-brand-blue/30');
            tag.classList.add('text-white/40', 'bg-white/5', 'border-white/5');
          }
          if (titleText) {
            titleText.classList.remove('text-white');
            titleText.classList.add('text-white/60');
          }
          if (descText) {
            descText.classList.remove('text-white/45');
            descText.classList.add('text-white/30');
          }
        }
      });

      // 2. Update active button classes for mobile horizontal scroll
      const mobColors = [
        { active: 'bg-emerald-500/20 border-emerald-500/40 text-white shadow-[0_0_12px_rgba(16,185,129,0.25)]', inactive: 'bg-surface-1/40 border-white/5 text-white/40' },
        { active: 'bg-blue-500/20 border-blue-500/40 text-white shadow-[0_0_12px_rgba(20,0,255,0.25)]', inactive: 'bg-surface-1/40 border-white/5 text-white/40' },
        { active: 'bg-violet-500/20 border-violet-500/40 text-white shadow-[0_0_12px_rgba(168,85,247,0.25)]', inactive: 'bg-surface-1/40 border-white/5 text-white/40' },
        { active: 'bg-amber-500/20 border-amber-500/40 text-white shadow-[0_0_12px_rgba(245,158,11,0.25)]', inactive: 'bg-surface-1/40 border-white/5 text-white/40' },
        { active: 'bg-cyan-500/20 border-cyan-500/40 text-white shadow-[0_0_12px_rgba(6,182,212,0.25)]', inactive: 'bg-surface-1/40 border-white/5 text-white/40' },
        { active: 'bg-pink-500/20 border-pink-500/40 text-white shadow-[0_0_12px_rgba(236,72,153,0.25)]', inactive: 'bg-surface-1/40 border-white/5 text-white/40' },
        { active: 'bg-blue-500/20 border-blue-500/40 text-white shadow-[0_0_12px_rgba(59,130,246,0.25)]', inactive: 'bg-surface-1/40 border-white/5 text-white/40' }
      ];

      mobileButtons.forEach((btn, i) => {
        if (i === idx) {
          btn.className = `pos-btn-mob px-3.5 py-1.5 rounded-full border text-[10px] font-mono tracking-tight transition-all duration-300 flex items-center gap-1.5 font-bold cursor-pointer ${mobColors[i].active}`;
        } else {
          btn.className = `pos-btn-mob px-3.5 py-1.5 rounded-full border text-[10px] font-mono tracking-tight transition-all duration-300 flex items-center gap-1.5 font-bold cursor-pointer ${mobColors[i].inactive}`;
        }
      });

      // Update indicators
      if (modeLabel) modeLabel.textContent = `Mode: ${activeTheme.mode}`;
      updateLaserLine();

      // Adjust Dynamic Blurs & Colors of parent console and bg spotlights
      if (consoleGlow) {
        consoleGlow.className = `absolute inset-0 bg-radial ${activeTheme.glow} via-transparent to-transparent opacity-60 z-0 pointer-events-none transition-all duration-500`;
      }
      if (bgGlow) {
        // Shift ambient glow spotlight color to match active index theme
        if (idx === 0) bgGlow.style.backgroundColor = 'rgba(16, 185, 129, 0.05)';
        else if (idx === 1) bgGlow.style.backgroundColor = 'rgba(20, 0, 255, 0.05)';
        else if (idx === 2) bgGlow.style.backgroundColor = 'rgba(168, 85, 247, 0.05)';
        else if (idx === 3) bgGlow.style.backgroundColor = 'rgba(245, 158, 11, 0.05)';
        else if (idx === 4) bgGlow.style.backgroundColor = 'rgba(6, 182, 212, 0.05)';
        else if (idx === 5) bgGlow.style.backgroundColor = 'rgba(236, 72, 153, 0.05)';
        else if (idx === 6) bgGlow.style.backgroundColor = 'rgba(59, 130, 246, 0.05)';
      }

      // 3. Cross-fade simulation cards
      const prevCard = cards[activeIndex];
      const nextCard = cards[idx];

      gsap.killTweensOf([prevCard, nextCard]);

      // Hide previous card
      gsap.fromTo(prevCard, 
        { opacity: 1, scale: 1 },
        {
          opacity: 0,
          scale: 0.95,
          duration: 0.35,
          ease: 'power2.inOut',
          onComplete: () => {
            (prevCard as HTMLElement).style.pointerEvents = 'none';
            (prevCard as HTMLElement).style.zIndex = '0';
          }
        }
      );

      // Show new card
      gsap.fromTo(nextCard, 
        { opacity: 0, scale: 0.95 },
        {
          opacity: 1,
          scale: 1,
          duration: 0.5,
          ease: 'power3.out',
          delay: 0.15,
          onStart: () => {
            (nextCard as HTMLElement).style.pointerEvents = 'auto';
            (nextCard as HTMLElement).style.zIndex = '10';
          },
          onComplete: () => {
            triggerInnerAnimation(idx);
          }
        }
      );

      activeIndex = idx;
    };

    // ── Autoplay Slideshow Mode ──
    const startAutoplay = () => {
      stopAutoplay();
      autoPlayTimer = setInterval(() => {
        const nextIdx = (activeIndex + 1) % desktopButtons.length;
        switchSandbox(nextIdx);
      }, 7000); // Shift slide every 7 seconds
    };

    const stopAutoplay = () => {
      if (autoPlayTimer) {
        clearInterval(autoPlayTimer);
        autoPlayTimer = null;
      }
    };

    // Listen to manual button clicks - autoplay continues
    desktopButtons.forEach((btn, idx) => {
      btn.addEventListener('click', () => {
        playClickSound();
        switchSandbox(idx);
        startAutoplay();
      });
    });
    mobileButtons.forEach((btn, idx) => {
      btn.addEventListener('click', () => {
        playClickSound();
        switchSandbox(idx);
        startAutoplay();
      });
    });

    // Click burst handler for manual user clicks on the CTA button
    const actionBtn = document.getElementById('pos-action-btn');
    if (actionBtn) {
      actionBtn.addEventListener('click', () => {
        playClickSound();
        
        // Scale bounce animation
        gsap.killTweensOf(actionBtn);
        gsap.timeline()
          .to(actionBtn, { scale: 0.92, duration: 0.1, ease: 'power2.out' })
          .to(actionBtn, { scale: 1, duration: 0.2, ease: 'back.out(1.5)' });
        
        // Trigger particle burst at the center of the button relative to parent
        const rect = actionBtn.getBoundingClientRect();
        const parentRect = actionBtn.parentElement!.getBoundingClientRect();
        const x = rect.left - parentRect.left + rect.width / 2;
        const y = rect.top - parentRect.top + rect.height / 2;
        triggerBurst(x, y, actionBtn.parentElement!);
      });
    }

    // Handle laser repositioning on screen resize
    window.addEventListener('resize', updateLaserLine);

    // Refresh ScrollTrigger to ensure correct placement calculations
    ScrollTrigger.refresh();
  };

  // Prevent race condition if loaderComplete has already fired
  const preloader = document.getElementById('preloader');
  if (!preloader || preloader.style.display === 'none') {
    initPositioningAnimations();
  } else {
    window.addEventListener('loaderComplete', initPositioningAnimations);
  }
</script>
