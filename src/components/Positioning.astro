    border-radius: 3px;
  }

  .pos-mob-scroll::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.6);
  }

  .pos-mob-scroll::-moz-scrollbar {
    height: 6px;
  }

  .pos-mob-scroll::-moz-scrollbar-track {
    background: rgba(255, 255, 255, 0.08);
