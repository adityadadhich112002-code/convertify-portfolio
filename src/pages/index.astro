---
import Layout from '../layouts/Layout.astro';
import Preloader from '../components/Preloader.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import BentoMetrics from '../components/BentoMetrics.astro';
import FounderTeaser from '../components/FounderTeaser.astro';
import PainSection from '../components/PainSection.astro';
import Portfolio from '../components/Portfolio.astro';
import Positioning from '../components/Positioning.astro';
import WhyUs from '../components/WhyUs.astro';
import TrustQuestion from '../components/TrustQuestion.astro';
import Founder from '../components/Founder.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- Global interactive overlay elements -->
  <Preloader />
  <CustomCursor />
  <Navbar />
  
  <!-- Main content wrapper -->
  <main class="relative">
    <Hero />
    <BentoMetrics />
    <FounderTeaser />
    <PainSection />
    <Portfolio />
    <Positioning />
    <WhyUs />
    <TrustQuestion />
    <Founder />
    <CTA />
  </main>
  
  <Footer />
</Layout>
