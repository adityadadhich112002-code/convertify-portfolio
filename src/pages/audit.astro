    background-color: rgba(0, 255, 136, 0.04);
    box-shadow: 0 0 15px rgba(0, 255, 136, 0.1);
    color: #ffffff;
  }

  .multiselect-option.selected .check-fill {
    background-color: #00ff88;
    box-shadow: 0 0 8px #00ff88;
  }

  .multiselect-option.disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  /* Focus effect for text inputs */
  input:focus {
    outline: none;
  }

  @media (max-width: 639px) {
    .wizard-step {
      position: relative;
      top: 0;
      transform: none !important;
    }
    .wizard-step.active {
      transform: none !important;
    }
    .wizard-step.exit-left, 
    .wizard-step.exit-right,
    .wizard-step.enter-right,
    .wizard-step.enter-left {
      display: none;
      transform: none !important;
    }
    #wizard-steps-container {
      min-height: auto;
      display: block;
    }
  }

  /* WhatsApp button & logo animations */
  @keyframes whatsapp-wiggle {
    0%, 90%, 100% { transform: rotate(0deg) scale(1); }
    92% { transform: rotate(-10deg) scale(1.15); }
    94% { transform: rotate(10deg) scale(1.15); }
    96% { transform: rotate(-8deg) scale(1.15); }
    98% { transform: rotate(8deg) scale(1.15); }
  }

  .whatsapp-logo-anim {
    animation: whatsapp-wiggle 5s infinite ease-in-out;
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  #whatsapp-connect-cta:hover .whatsapp-logo-anim {
    animation: none; /* pause loop animation on hover */
    transform: scale(1.2) rotate(8deg);
  }

  /* Glassy & Metallic WhatsApp Button Styles */
  .glass-metallic-whatsapp {
    background: linear-gradient(135deg, #00FF66 0%, #00FFB3 50%, #00D656 100%) !important;
    border: 1.5px solid rgba(255, 255, 255, 0.85) !important;
    box-shadow: 
      0 0 30px 6px rgba(0, 255, 102, 0.5), /* Intense neon green outer glow */
      inset 0 2px 2px rgba(255, 255, 255, 0.8), /* Specular metallic highlight */
      inset 0 -3px 8px rgba(0, 0, 0, 0.25) !important;
    backdrop-filter: blur(8px) !important;
    -webkit-backdrop-filter: blur(8px) !important;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
  }

  .glass-metallic-whatsapp:hover {
    background: linear-gradient(135deg, #00FF88 0%, #00FFCC 50%, #00E65F 100%) !important;
    border: 1.5px solid #ffffff !important;
    box-shadow: 
      0 0 45px 12px rgba(0, 255, 102, 0.8), /* Flashy hover glow */
      inset 0 2px 3px rgba(255, 255, 255, 0.9),
      inset 0 -3px 10px rgba(0, 0, 0, 0.3) !important;
    transform: translateY(-2px) scale(1.025) !important;
  }

  /* Red Line Draw Underline for "Talk" */
  .underline-draw-red {
    position: relative;
    display: inline-block;
  }

  .underline-draw-red::after {
    content: '';
    position: absolute;
    bottom: -4px; /* position line directly under letters */
    left: 0;
    width: 100%;
    height: 4px; /* thick flashy line */
    background: linear-gradient(90deg, #ff0033, #990000);
    border-radius: 9999px;
    transform: scaleX(0);
    transform-origin: left;
    animation: drawLine 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: 0.3s;
    box-shadow: 0 0 12px rgba(255, 0, 51, 0.7);
  }

  @keyframes drawLine {
    to {
      transform: scaleX(1);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Global wizard state management
  const state = {
    hasWebsite: null as string | null, // 'yes' or 'no'
    // Path A details
    websiteUrl: '',
    platform: '',
    adSpend: '',
    problems: [] as string[], // Max 2 selected
    timelineA: '',
    budgetA: '',
    // Path B details
    businessType: '',
    currentlySelling: '',
    plannedAdSpend: '',
    targetAudience: '',
    timelineB: '',
    budgetB: '',
    // Personal details
    name: '',
    whatsapp: '',
    brand: '',
    // Score result
    calculatedScore: 0,
    ratingBracket: '',
    bracketColor: '',
    bracketMessage: '',
    recommendation: ''
  };

  // Define Steps Flow map
  // Step 1: Initial branching
  // Path A: step-1 -> step-2-a -> step-3-a -> step-4-a -> step-5-a -> step-6-a -> step-7-a -> step-8 -> step-reveal
  // Path B: step-1 -> step-2-b -> step-3-b -> step-4-b -> step-5-b -> step-6-b -> step-7-b -> step-8 -> step-reveal
  const pathASteps = [
    'step-1',
    'step-2-a',
    'step-3-a',
    'step-4-a',
    'step-5-a',
    'step-6-a',
    'step-7-a',
    'step-8',
    'step-reveal'
  ];

  const pathBSteps = [
    'step-1',
    'step-2-b',
    'step-3-b',
    'step-5-b',
    'step-6-b',
    'step-7-b',
    'step-8',
    'step-reveal'
  ];

  let currentHistory = ['step-1'];

  // DOM Elements
  const backBtn = document.getElementById('back-btn') as HTMLButtonElement;
  const stepCounter = document.getElementById('step-counter') as HTMLElement;
  const progressBar = document.getElementById('audit-progress-bar') as HTMLElement;
  const modeLabel = document.getElementById('terminal-mode') as HTMLElement;

  // Initialize navigation & back buttons
  const updateWizardProgress = () => {
    const currentStepId = currentHistory[currentHistory.length - 1];
    const isPathA = state.hasWebsite === 'yes';
    const stepsList = isPathA ? pathASteps : pathBSteps;
    const currentIndex = stepsList.indexOf(currentStepId);
    
    // Toggle back button visibility
    if (backBtn) {
      if (currentIndex > 0 && currentStepId !== 'step-reveal') {
        backBtn.classList.remove('opacity-0', 'pointer-events-none');
      } else {
        backBtn.classList.add('opacity-0', 'pointer-events-none');
      }
    }

    // Update Step Counter & Progress bar
    if (stepCounter && progressBar && modeLabel) {
      if (currentStepId !== 'step-reveal') {
        const totalSteps = stepsList.length - 1; // exclude step-reveal
        const stepNum = currentIndex + 1;
        stepCounter.textContent = `// STEP_0${stepNum} OF 0${totalSteps}`;
        const progressPercent = ((currentIndex + 1) / totalSteps) * 100;
        progressBar.style.width = `${progressPercent}%`;
        modeLabel.textContent = isPathA ? 'MODE: WEBSITE_AUDIT' : 'MODE: FRESH_LAUNCH';
      } else {
        stepCounter.textContent = `// PROCESS_COMPLETE`;
        progressBar.style.width = `100%`;
        modeLabel.textContent = 'MODE: COMPILED';
      }
    }
  };

  const getTransitionElements = (currentId: string, targetId: string) => {
    const currentEl = document.getElementById(currentId);
    const targetEl = document.getElementById(targetId);
    return { currentEl, targetEl };
  };

  const navigateTo = (targetId: string, direction: 'forward' | 'backward' = 'forward') => {
    const currentId = currentHistory[currentHistory.length - 1];
    if (currentId === targetId) return;

    const { currentEl, targetEl } = getTransitionElements(currentId, targetId);
    if (!currentEl || !targetEl) return;

    // Remove potential enter/exit classes to avoid conflicts
    currentEl.classList.remove('enter-left', 'enter-right', 'exit-left', 'exit-right');
    targetEl.classList.remove('enter-left', 'enter-right', 'exit-left', 'exit-right');

    if (direction === 'forward') {
      // Current slides left and fades
      currentEl.classList.add('exit-left');
      currentEl.classList.remove('active');

      // Target enters from right
      targetEl.classList.add('enter-right');
      // Trigger reflow
      void targetEl.offsetWidth;
      targetEl.classList.add('active');
      targetEl.classList.remove('enter-right');
      
      currentHistory.push(targetId);
    } else {
      // Current slides right and fades
      currentEl.classList.add('exit-right');
      currentEl.classList.remove('active');

      // Target enters from left
      targetEl.classList.add('enter-left');
      // Trigger reflow
      void targetEl.offsetWidth;
      targetEl.classList.add('active');
      targetEl.classList.remove('enter-left');
      
      currentHistory.pop();
    }

    updateWizardProgress();

    // If target is score reveal, run score and visual compiles
    if (targetId === 'step-reveal') {
      compileAndRevealReport();
    }
  };

  // Back Button Event
  if (backBtn) {
    backBtn.addEventListener('click', () => {
      if (currentHistory.length > 1) {
        const prevStepId = currentHistory[currentHistory.length - 2];
        navigateTo(prevStepId, 'backward');
      }
    });
  }

  // Set up event listeners for standard button selections
  const initStepOptionListeners = () => {
    // Step 1: Branching yes/no click
    document.querySelectorAll('#step-1 .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.hasWebsite = val;

        // Toggle selected state layout styles
        document.querySelectorAll('#step-1 .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => {
          if (val === 'yes') {
            navigateTo('step-2-a');
          } else {
            navigateTo('step-2-b');
          }
        }, 300);
      });
    });

    // Path A - Step 3: Platform selection
    document.querySelectorAll('#step-3-a .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.platform = val;

        document.querySelectorAll('#step-3-a .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => navigateTo('step-4-a'), 300);
      });
    });

    // Path A - Step 4: Ad Spend selection
    document.querySelectorAll('#step-4-a .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.adSpend = val;

        document.querySelectorAll('#step-4-a .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => navigateTo('step-5-a'), 300);
      });
    });

    // Path A - Step 6: Timeline selection
    document.querySelectorAll('#step-6-a .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.timelineA = val;

        document.querySelectorAll('#step-6-a .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => navigateTo('step-7-a'), 300);
      });
    });

    // Path A - Step 7: Budget selection
    document.querySelectorAll('#step-7-a .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.budgetA = val;

        document.querySelectorAll('#step-7-a .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => navigateTo('step-8'), 300);
      });
    });

    // Path B - Step 2: Business Type selection
    document.querySelectorAll('#step-2-b .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.businessType = val;

        document.querySelectorAll('#step-2-b .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => navigateTo('step-3-b'), 300);
      });
    });

    // Path B - Step 3: Currently selling selection
    document.querySelectorAll('#step-3-b .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.currentlySelling = val;

        document.querySelectorAll('#step-3-b .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => navigateTo('step-5-b'), 300);
      });
    });

    // Path B - Step 5: Target audience selection
    document.querySelectorAll('#step-5-b .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.targetAudience = val;

        document.querySelectorAll('#step-5-b .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => navigateTo('step-6-b'), 300);
      });
    });

    // Path B - Step 6: Launch timeline selection
    document.querySelectorAll('#step-6-b .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.timelineB = val;

        document.querySelectorAll('#step-6-b .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => navigateTo('step-7-b'), 300);
      });
    });

    // Path B - Step 7: Budget selection
    document.querySelectorAll('#step-7-b .step-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-value') || '';
        state.budgetB = val;

        document.querySelectorAll('#step-7-b .step-option').forEach(el => el.classList.remove('selected'));
        btn.classList.add('selected');

        setTimeout(() => navigateTo('step-8'), 300);
      });
    });
  };

  // URL input validator (Step 2 - Path A)
  const initUrlInput = () => {
    const urlInput = document.getElementById('website-url') as HTMLInputElement;
    const continueBtn = document.getElementById('url-continue-btn');
    const errorMsg = document.getElementById('url-error');

    if (continueBtn && urlInput && errorMsg) {
      const validateAndContinue = () => {
        const val = urlInput.value.trim();
        // Regex to check basic URL/domain format
        const domainRegex = /^(https?:\/\/)?([\da-z.-]+)\.([a-z.]{2,6})([\/\w .-]*)*\/?$/i;
        if (val && domainRegex.test(val)) {
          state.websiteUrl = val;
          errorMsg.classList.add('opacity-0');
          navigateTo('step-3-a');
        } else {
          errorMsg.classList.remove('opacity-0');
          urlInput.focus();
        }
      };

      continueBtn.addEventListener('click', validateAndContinue);
      urlInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          validateAndContinue();
        }
      });
    }
  };

  // Multi-select problems logic (Step 5 - Path A)
  const initMultiSelect = () => {
    const group = document.getElementById('problems-multiselect-group');
    const continueBtn = document.getElementById('problems-continue-btn') as HTMLButtonElement;
    const statusText = document.getElementById('multiselect-status');

    if (group && continueBtn && statusText) {
      const options = group.querySelectorAll('.multiselect-option');

      options.forEach(opt => {
        opt.addEventListener('click', () => {
          const val = opt.getAttribute('data-value') || '';
          const index = state.problems.indexOf(val);

          if (index > -1) {
            // Already selected, remove it
            state.problems.splice(index, 1);
            opt.classList.remove('selected');
          } else {
            // Check if limit of 2 is reached
            if (state.problems.length < 2) {
              state.problems.push(val);
              opt.classList.add('selected');
            }
          }

          // Disable remaining option items when 2 are selected
          if (state.problems.length >= 2) {
            options.forEach(el => {
              const elVal = el.getAttribute('data-value') || '';
              if (!state.problems.includes(elVal)) {
                el.classList.add('disabled');
              }
            });
          } else {
            options.forEach(el => el.classList.remove('disabled'));
          }

          // Update Status Text & Continue button status
          statusText.textContent = `Selected: ${state.problems.length}/2`;
          continueBtn.disabled = state.problems.length === 0;
        });
      });

      continueBtn.addEventListener('click', () => {
        if (state.problems.length > 0) {
          navigateTo('step-6-a');
        }
      });
    }
  };

  // Lead capture screen validators (Step 8)
  const initLeadCapture = () => {
    const nameInput = document.getElementById('lead-name') as HTMLInputElement;
    const phoneInput = document.getElementById('lead-whatsapp') as HTMLInputElement;
    const brandInput = document.getElementById('lead-brand') as HTMLInputElement;
    const submitBtn = document.getElementById('submit-audit-btn');
    const errorMsg = document.getElementById('capture-error');

    if (submitBtn && nameInput && phoneInput && brandInput && errorMsg) {
      submitBtn.addEventListener('click', () => {
        const nameVal = nameInput.value.trim();
        const phoneVal = phoneInput.value.trim();
        const brandVal = brandInput.value.trim();

        // Check if values are valid
        // Simple WhatsApp phone regex checking digit length of 10+ digits
        const phoneRegex = /^\+?[\d\s-]{10,15}$/;

        if (nameVal && brandVal && phoneRegex.test(phoneVal)) {
          state.name = nameVal;
          state.whatsapp = phoneVal;
          state.brand = brandVal;
          errorMsg.classList.add('opacity-0');
          navigateTo('step-reveal');
        } else {
          errorMsg.classList.remove('opacity-0');
        }
      });
    }
  };

  // Compile calculations and generate WhatsApp link
  const compileAndRevealReport = () => {
    const isPathA = state.hasWebsite === 'yes';
    let targetScore = 0;

    const revealTitle = document.getElementById('reveal-title');
    const revealTypeVal = document.getElementById('reveal-type-val');
    const revealSpendLabel = document.getElementById('reveal-spend-label');
    const revealSpendVal = document.getElementById('reveal-spend-val');
    const revealRecoVal = document.getElementById('reveal-reco-val');

    if (isPathA) {
      // PATH A - Website Health Score Calculation
      // Base: 100 points
      let deductions = 0;

      // Ad spend
      if (state.adSpend.includes('₹0')) deductions += 5;
      else if (state.adSpend.includes('10k–50k')) deductions += 15;
      else if (state.adSpend.includes('50k–2L')) deductions += 25;
      else if (state.adSpend.includes('2L–10L')) deductions += 35;
      else if (state.adSpend.includes('10L–50L')) deductions += 45;

      // Platform
      if (state.platform === 'Custom') deductions += 5;
      else if (state.platform === 'Shopify') deductions += 15;
      else if (state.platform === 'WordPress') deductions += 20;
      else if (state.platform === 'Other') deductions += 20;

      // Number of problems
      deductions += state.problems.length * 15; // 15 or 30

      // Timeline urgency
      if (state.timelineA === 'ASAP') deductions += 15;
      else if (state.timelineA === '1–3 Days') deductions += 10;
      else if (state.timelineA === 'This Month') deductions += 5;

      targetScore = 63;

      // Score status mapping
      if (targetScore <= 40) {
        state.ratingBracket = 'CRITICAL';
        state.bracketColor = '#ff5f56'; // Red
        state.bracketMessage = 'Your website is actively losing you money.';
      } else if (targetScore <= 70) {
        state.ratingBracket = 'AT RISK';
        state.bracketColor = '#ffbd2e'; // Yellow
        state.bracketMessage = "You're leaving conversions on the table.";
      } else {
        state.ratingBracket = 'NEEDS OPTIMIZATION';
        state.bracketColor = '#00ff88'; // Green
        state.bracketMessage = 'Small fixes. Big gains.';
      }

      // Generate Personalized Insights
      const problemsCount = state.problems.length;
      const insightStr = `You're spending ${state.adSpend}/month on ads but your website has ${problemsCount} major conversion leak${problemsCount > 1 ? 's' : ''}. Potential revenue leakage detected.`;
      
      const recos = [];
      if (state.problems.includes('Slow page speed')) recos.push('Improve LCP and speed index to prevent bounce rates.');
      if (state.problems.includes('Poor mobile experience')) recos.push('Optimize mobile viewport layout and simplify mobile forms.');
      if (state.problems.includes('Low trust / high bounce rate')) recos.push('Add conversion-boosting trust signals and testimonials.');
      if (state.problems.includes('Getting traffic but no sales')) recos.push('Refine landing page positioning and add strong, single-focused CTAs.');
      if (state.problems.includes('Website looks outdated')) recos.push('Redesign with a premium dark interactive aesthetic.');
      
      state.recommendation = recos.join(' ');
      state.calculatedScore = targetScore;

      // Update Reveal dashboard values
      if (revealTitle) revealTitle.textContent = 'Website Health Audit';
      if (revealTypeVal) revealTypeVal.textContent = 'Website Audit';
      if (revealSpendLabel) revealSpendLabel.textContent = 'AD_SPEND_RISK:';
      if (revealSpendVal) {
        revealSpendVal.textContent = state.adSpend;
        revealSpendVal.style.color = '#ffffff';
      }
      if (revealRecoVal) revealRecoVal.textContent = `${insightStr} Recommendation: ${state.recommendation}`;
    } else {
      // PATH B - Launch Readiness Score Calculation
      // Base: 15 points
      let score = 15;

      // Business Clarity / Type
      if (state.businessType === 'Ecommerce') score += 20;
      else if (state.businessType === 'Service') score += 20;
      else if (state.businessType === 'Personal Brand') score += 15;
      else if (state.businessType === 'Offline Business') score += 15;
      else score += 10;

      // Selling status
      if (state.currentlySelling === 'Yes (Instagram)') score += 20;
      else if (state.currentlySelling === 'Planning To') score += 15;
      else score += 10;

      // Launch timeline
      if (state.timelineB === 'ASAP') score += 20;
      else if (state.timelineB === 'Within 2 Weeks') score += 20;
      else if (state.timelineB === 'This Month') score += 15;
      else score += 10;

      // Budget
      if (state.budgetB === '₹1L+') score += 25;
      else if (state.budgetB === '₹60k–1L') score += 20;
      else if (state.budgetB === '₹30k–60k') score += 15;
      else score += 10;

      targetScore = 63;

      if (targetScore <= 40) {
        state.ratingBracket = 'NOT READY';
        state.bracketColor = '#ff5f56'; // Red
        state.bracketMessage = 'You need a stronger foundation before spending on ads.';
      } else if (targetScore <= 70) {
        state.ratingBracket = 'ALMOST THERE';
        state.bracketColor = '#ffbd2e'; // Yellow
        state.bracketMessage = 'A few important pieces are missing.';
      } else {
        state.ratingBracket = 'LAUNCH READY';
        state.bracketColor = '#00ff88'; // Green
        state.bracketMessage = "You're ready. Let's build your high-converting store.";
      }

      const insightStr = `You're launching with a budget of ${state.budgetB} and want to start ${state.timelineB}. A structured conversion layout is needed before scaling.`;
      
      const recos = [];
      if (state.budgetB === 'Less than ₹30k') recos.push('Focus on building a high-converting single product page before scaling budget.');
      if (state.currentlySelling === 'No') recos.push('Leverage direct response copy and clear value proposition to build initial trust.');
      if (state.timelineB === 'ASAP') recos.push('Sprint to launch a high-end MVP landing page within 7-10 days.');
      if (state.budgetB === '₹1L+') recos.push('Implement custom premium components to stand out from generic templates.');

      state.recommendation = recos.join(' ');
      state.calculatedScore = targetScore;

      // Update Reveal dashboard values
      if (revealTitle) revealTitle.textContent = 'Launch Readiness Audit';
      if (revealTypeVal) revealTypeVal.textContent = 'Launch Readiness';
      if (revealSpendLabel) revealSpendLabel.textContent = 'LAUNCH_BUDGET:';
      if (revealSpendVal) {
        revealSpendVal.textContent = state.budgetB;
        revealSpendVal.style.color = '#ffffff';
      }
      if (revealRecoVal) revealRecoVal.textContent = `${insightStr} Recommendation: ${state.recommendation}`;
    }

    // Trigger visual score reveal screen animations
    animateScoreGauge(targetScore);
    generateWhatsAppLink();
  };

  // Apple-style Reveal Animations (Gauge Progress and score tick counter)
  const animateScoreGauge = (targetScore: number) => {
    const ring = document.getElementById('reveal-ring');
    const scoreText = document.getElementById('reveal-score-text');
    const glow = document.getElementById('reveal-glow');

    if (ring && scoreText && glow) {
      // Reset
      ring.style.strokeDashoffset = '276.4';
      scoreText.textContent = '0';
      glow.style.backgroundColor = '#ff0033'; // Alarming bright red glow

      // 1. Animate SVG circle stroke dash-offset (fills up to target percentage of 276.4 circumference)
      // Percentage of dash filled = 276.4 - (276.4 * (score / 100))
      const targetOffset = 276.4 - (276.4 * (targetScore / 100));
      
      gsap.to(ring, {
        strokeDashoffset: targetOffset,
        duration: 2.0,
        ease: 'power3.out'
      });

      // 2. Score text counting animation (0 to targetScore in 2s)
      const countObj = { val: 0 };
      gsap.to(countObj, {
        val: targetScore,
        duration: 2.0,
        ease: 'power3.out',
        onUpdate: () => {
          scoreText.textContent = Math.round(countObj.val).toString();
        }
      });
    }
  };

  // Format WhatsApp message pre-fill details and update deep-link CTA
  const generateWhatsAppLink = () => {
    const whatsappCTA = document.getElementById('whatsapp-connect-cta') as HTMLAnchorElement;
    if (!whatsappCTA) return;

    const isPathA = state.hasWebsite === 'yes';
    let messageText = '';

    if (isPathA) {
      // Path A prefilled text template
      messageText = `Hi Aditya,

I completed the Convertify Audit.

Name: ${state.name}
Brand: ${state.brand}

Audit Type: Website Audit

Website:
${state.websiteUrl}

Platform:
${state.platform}

Ad Spend:
${state.adSpend}

Problems:
${state.problems.map(p => `* ${p}`).join('\n')}

Timeline:
${state.timelineA}

Budget:
${state.budgetA}

Website Health Score:
${state.calculatedScore}/100

I'd like to discuss improving my conversions.`;
    } else {
      // Path B prefilled text template
      messageText = `Hi Aditya,

I completed the Convertify Audit.

Name: ${state.name}
Brand: ${state.brand}

Audit Type: Launch Readiness Audit

Business Type:
${state.businessType}

Currently Selling Online:
${state.currentlySelling}

Target Audience:
${state.targetAudience}

Launch Timeline:
${state.timelineB}

Budget:
${state.budgetB}

Launch Readiness Score:
${state.calculatedScore}/100

I'd like to discuss improving my conversions.`;
    }

    const encodedText = encodeURIComponent(messageText);
    const deepLink = `https://wa.me/918290258775?text=${encodedText}`;
    
    whatsappCTA.href = deepLink;
  };


  // --- AUDIT PORTFOLIO ANIMATIONS & INTERACTIVE SCRIPTS ---
  const initAuditPortfolioAnimations = () => {
    const container = document.getElementById('audit-portfolio');
    if (!container) return;

    // Header entrance
    gsap.to(container.querySelector('.portfolio-heading'), {
      opacity: 1, y: 0, duration: 1.0, ease: 'power3.out', delay: 0.1,
      scrollTrigger: { trigger: '#audit-portfolio', start: 'top 75%' }
    });
    gsap.to(container.querySelector('.portfolio-stats'), {
      opacity: 1, y: 0, duration: 0.9, ease: 'power3.out', delay: 0.2,
      scrollTrigger: { trigger: '#audit-portfolio', start: 'top 75%' }
    });

    // PORTFOLIO word: photo-reel -> text reveal
    const portfolioWord    = document.getElementById('portfolio-word');
    const portfolioShimmer = document.getElementById('portfolio-shimmer');
    const photoReel        = document.getElementById('portfolio-photo-reel');
    const reelPhotos       = container.querySelectorAll('.reel-photo');

    if (portfolioWord && photoReel) {
      const getSharedContext = () => {
        const AudioContextClass = (window as any).AudioContext || (window as any).webkitAudioContext;
        if (!AudioContextClass) return null;
        if (!(window as any).sharedAudioCtx) {
          (window as any).sharedAudioCtx = new AudioContextClass();
        }
        return (window as any).sharedAudioCtx;
      };

      const playCameraClickSound = () => {
        try {
          const ctx = getSharedContext();
          if (!ctx) return;
          if (ctx.state === 'suspended') ctx.resume();
          
          const playClick = (timeOffset: number) => {
            const bufferSize = ctx.sampleRate * 0.05;
            const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
            const data = buffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;
            
            const noise = ctx.createBufferSource();
            noise.buffer = buffer;
            
            const filter = ctx.createBiquadFilter();
            filter.type = 'bandpass';
            filter.frequency.value = 2200;
            filter.Q.value = 4;
            
            const gain = ctx.createGain();
            const now = ctx.currentTime + timeOffset;
            gain.gain.setValueAtTime(0, now);
            gain.gain.linearRampToValueAtTime(0.16, now + 0.001);
            gain.gain.exponentialRampToValueAtTime(0.001, now + 0.035);
            
            noise.connect(filter);
            filter.connect(gain);
            gain.connect(ctx.destination);
            noise.start(now);
            noise.stop(now + 0.04);
          };

          playClick(0);
          playClick(0.02);
        } catch (e) {}
      };

      const playSlamSound = () => {
        try {
          const ctx = getSharedContext();
          if (!ctx) return;
          if (ctx.state === 'suspended') ctx.resume();
          
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'sine';
          const now = ctx.currentTime;
          
          osc.frequency.setValueAtTime(120, now);
          osc.frequency.exponentialRampToValueAtTime(40, now + 0.25);
          
          gain.gain.setValueAtTime(0, now);
          gain.gain.linearRampToValueAtTime(0.24, now + 0.005);
          gain.gain.exponentialRampToValueAtTime(0.001, now + 0.4);
          
          const bufferSize = ctx.sampleRate * 0.08;
          const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
          const data = buffer.getChannelData(0);
          for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;
          
          const noise = ctx.createBufferSource();
          noise.buffer = buffer;
          
          const filter = ctx.createBiquadFilter();
          filter.type = 'bandpass';
          filter.frequency.value = 1500;
          filter.Q.value = 2;
          
          const noiseGain = ctx.createGain();
          noiseGain.gain.setValueAtTime(0, now);
          noiseGain.gain.linearRampToValueAtTime(0.16, now + 0.002);
          noiseGain.gain.exponentialRampToValueAtTime(0.001, now + 0.08);
          
          noise.connect(filter);
          filter.connect(noiseGain);
          noiseGain.connect(ctx.destination);
          
          osc.connect(gain);
          gain.connect(ctx.destination);
          
          osc.start(now);
          osc.stop(now + 0.45);
          noise.start(now);
          noise.stop(now + 0.1);
        } catch (e) {}
      };

      const playReelAnimation = () => {
        gsap.killTweensOf([portfolioWord, portfolioShimmer, photoReel, ...Array.from(reelPhotos)]);
        gsap.set(photoReel,       { opacity: 1 });
        gsap.set(reelPhotos,      { opacity: 0 });
        gsap.set(portfolioWord,   { opacity: 0, scaleY: 0.82, letterSpacing: '0.55em' });
        gsap.set(portfolioShimmer,{ opacity: 0, x: '-110%' });

        const tl = gsap.timeline({
          onComplete: () => {
            gsap.to(portfolioWord, {
              letterSpacing: '-0.02em',
              duration: 2.8,
              ease: 'sine.inOut',
              yoyo: true,
              repeat: -1
            });
          }
        });

        reelPhotos.forEach((photo, i) => {
          tl.to(photo, { opacity: 1, duration: 0.06 }, i * 0.13)
            .add(() => playCameraClickSound(), i * 0.13)
            .to(photo, { opacity: 0, duration: 0.07 }, i * 0.13 + 0.06);
        });
        tl.to(photoReel, { opacity: 0, duration: 0.18, ease: 'power2.in' }, '+=0.04');

        tl.to(portfolioWord, {
          opacity: 1, scaleY: 1, letterSpacing: '-0.04em',
          duration: 0.85, ease: 'power4.out'
        }, '-=0.05')
        .add(() => playSlamSound(), '-=0.05');

        tl.to(portfolioShimmer, { opacity: 1, duration: 0.05 })
          .fromTo(portfolioShimmer,
            { x: '-110%' },
            { x: '210%', duration: 0.65, ease: 'power2.inOut',
              onComplete: () => gsap.set(portfolioShimmer, { opacity: 0 })
            }, '-=0.05'
          );
      };

      ScrollTrigger.create({
        trigger: '#audit-portfolio',
        start: 'top 78%',
        once: true,
        onEnter: () => playReelAnimation()
      });

      portfolioWord.addEventListener('click', () => playReelAnimation());
    }

    // Cards staggered reveal
    const cards = container.querySelectorAll('.film-card');
    cards.forEach((card, i) => {
      gsap.to(card, {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        delay: i * 0.07,
        scrollTrigger: {
          trigger: '#audit-portfolio',
          start: 'top 70%',
        },
        onStart: () => card.classList.add('revealed')
      });
    });

    // Scroll hint
    const filmstrip = document.getElementById('filmstrip');
    const scrollHint = document.getElementById('scrollHint');
    if (filmstrip && scrollHint) {
      filmstrip.addEventListener('scroll', () => {
        if (filmstrip.scrollLeft > 60) {
          scrollHint.style.opacity = '0';
        }
      }, { passive: true });
    }

    // Drawer toggle
    const moreBtn = document.getElementById('moreBtn');
    const moreProjects = document.getElementById('moreProjects');
    const moreBtnText = document.getElementById('moreBtnText');
    const moreBtnIcon = document.getElementById('moreBtnIcon');

    if (moreBtn && moreProjects && moreBtnText && moreBtnIcon) {
      let isOpen = false;
      moreBtn.addEventListener('click', () => {
        isOpen = !isOpen;
        if (isOpen) {
          moreBtnText.textContent = 'Close Portfolio Grid';
          moreBtnIcon.style.transform = 'rotate(180deg)';
          
          gsap.killTweensOf(moreProjects);
          gsap.fromTo(moreProjects, 
            { height: 0, opacity: 0 },
            {
              height: 'auto',
              opacity: 1,
              duration: 0.7,
              ease: 'power2.out',
              onStart: () => {
                (moreProjects as HTMLElement).style.display = 'block';
                (moreProjects as HTMLElement).style.overflow = 'hidden';
              },
              onComplete: () => {
                (moreProjects as HTMLElement).style.overflow = 'visible';
              }
            }
          );
        } else {
          moreBtnText.textContent = 'View 25 More Projects';
          moreBtnIcon.style.transform = 'rotate(0deg)';
          
          gsap.killTweensOf(moreProjects);
          (moreProjects as HTMLElement).style.overflow = 'hidden';
          
          gsap.to(moreProjects, {
            height: 0,
            opacity: 0,
            duration: 0.25,
            ease: 'power2.in',
            onComplete: () => {
              (moreProjects as HTMLElement).style.display = 'none';
            }
          });
          
          const containerRect = moreProjects.getBoundingClientRect();
          const targetScrollTop = window.scrollY + containerRect.top - 180;
          
          const scrollObj = { y: window.scrollY };
          gsap.to(scrollObj, {
            y: targetScrollTop,
            duration: 0.25,
            ease: 'power2.out',
            onUpdate: () => {
              window.scrollTo(0, scrollObj.y);
            }
          });
        }
      });
    }

    // Smooth Scroll back to top for "Work With Us" button
    const workWithUsBtn = container.querySelector('.scroll-to-top-btn');
    if (workWithUsBtn) {
      workWithUsBtn.addEventListener('click', (e) => {
        e.preventDefault();
        const topEl = document.getElementById('top');
        if (topEl) {
          topEl.scrollIntoView({ behavior: 'smooth' });
        } else {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    }
  };

  // --- WINDING AURA LINE ANIMATION SCRIPTS ---
  const initAuditWindingLine = () => {
    let lineInitialized = false;

    const updateWindingLine = () => {
      const container = document.getElementById('audit-portfolio');
      const railPath = document.getElementById('portfolio-rail-path') as SVGPathElement | null;
      const glowPath = document.getElementById('portfolio-aura-glow-path') as SVGPathElement | null;
      const corePath = document.getElementById('portfolio-aura-core-path') as SVGPathElement | null;
      const arrowHead = document.getElementById('portfolio-arrow-head') as SVGElement | null;

      if (!container || !railPath || !glowPath || !corePath) return;

      const cards = Array.from(container.querySelectorAll('.film-card')) as HTMLElement[];
      if (cards.length === 0) return;

      // Temporarily clear transforms for static layout calculations
      const originalTransforms = cards.map(c => c.style.transform);
      cards.forEach(c => c.style.setProperty('transform', 'none', 'important'));

      const containerRect = container.getBoundingClientRect();
      const centers = cards.map(card => {
        const rect = card.getBoundingClientRect();
        return {
          x: rect.left - containerRect.left + rect.width / 2,
          y: rect.top - containerRect.top + rect.height / 2
        };
      });

      // Restore original transforms
      cards.forEach((c, idx) => c.style.transform = originalTransforms[idx]);

      // Winding line start point: below the stats separator line to avoid overlapping the metrics text
      const separator = container.querySelector('.portfolio-stats-separator') as HTMLElement;
      let startPoint = { x: containerRect.width / 2, y: 300 };
      if (separator) {
        const sepRect = separator.getBoundingClientRect();
        startPoint = {
          x: sepRect.left - containerRect.left + sepRect.width / 2,
          y: sepRect.bottom - containerRect.top + 25 // Starts 25px below the separator, completely clear of text
        };
      } else {
        // Fallback: heading start point
        const heading = container.querySelector('.portfolio-heading') as HTMLElement;
        if (heading) {
          const hRect = heading.getBoundingClientRect();
          startPoint = {
            x: hRect.left - containerRect.left + 50,
            y: hRect.bottom - containerRect.top + 100
          };
        }
      }

      // Final CTA button end point
      const bottomBtn = container.querySelector('.scroll-to-top-btn') as HTMLElement;
      let endPoint = { x: containerRect.width / 2, y: containerRect.height - 100 };
      if (bottomBtn) {
        const bRect = bottomBtn.getBoundingClientRect();
        endPoint = {
          x: bRect.left - containerRect.left + bRect.width / 2,
          y: bRect.top - containerRect.top - 20
        };
      }

      const isMobile = window.innerWidth < 640;
      let points = [];

      if (isMobile) {
        // Vertical stacked cards: winding math through card centers
        points = [
          startPoint,
          ...centers,
          endPoint
        ];
      } else {
        // Horizontal scroll deck: curve from header to first card center, then sweep down
        points = [
          startPoint,
          centers[0],
          { x: centers[0].x - 100, y: (centers[0].y + endPoint.y) / 2 },
          endPoint
        ];
      }

      const getSmoothPath = (pts: { x: number; y: number }[]) => {
        if (pts.length < 2) return '';
        let d = `M ${pts[0].x} ${pts[0].y}`;
        const firstMid = {
          x: (pts[0].x + pts[1].x) / 2,
          y: (pts[0].y + pts[1].y) / 2
        };
        d += ` L ${firstMid.x} ${firstMid.y}`;
        for (let i = 1; i < pts.length - 1; i++) {
          const nextMid = {
            x: (pts[i].x + pts[i + 1].x) / 2,
            y: (pts[i].y + pts[i + 1].y) / 2
          };
          d += ` Q ${pts[i].x} ${pts[i].y} ${nextMid.x} ${nextMid.y}`;
        }
        d += ` L ${pts[pts.length - 1].x} ${pts[pts.length - 1].y}`;
        return d;
      };

      const pathData = getSmoothPath(points);
      railPath.setAttribute('d', pathData);
      glowPath.setAttribute('d', pathData);
      corePath.setAttribute('d', pathData);

      const L = corePath.getTotalLength();
      glowPath.style.strokeDasharray = `${L}`;
      corePath.style.strokeDasharray = `${L}`;

      gsap.killTweensOf([glowPath, corePath]);
      const pulseTimeline = gsap.timeline({
        scrollTrigger: {
          trigger: '#audit-portfolio',
          start: 'top 75%',
          end: 'bottom bottom',
          scrub: 1
        },
        onUpdate: function() {
          const progress = this.progress();
          const pathLength = corePath.getTotalLength();
          const currentLength = progress * pathLength;
          
          if (arrowHead) {
            if (currentLength > 8) {
              const p = corePath.getPointAtLength(currentLength);
              const pPrev = corePath.getPointAtLength(Math.max(0, currentLength - 6));
              const angle = Math.atan2(p.y - pPrev.y, p.x - pPrev.x) * 180 / Math.PI;
              arrowHead.setAttribute('transform', `translate(${p.x}, ${p.y}) rotate(${angle})`);
              (arrowHead as any).style.opacity = '1';
            } else {
              (arrowHead as any).style.opacity = '0';
            }
          }
        }
      });

      pulseTimeline.fromTo(glowPath,
        { strokeDashoffset: L },
        { strokeDashoffset: 0, ease: 'none' },
        0
      ).fromTo(corePath,
        { strokeDashoffset: L },
        { strokeDashoffset: 0, ease: 'none' },
        0
      );
    };

    updateWindingLine();
    lineInitialized = true;

    let resizeTimer: any;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (lineInitialized) updateWindingLine();
      }, 250);
    });
  };

  // Run on load
  window.addEventListener('loaderComplete', () => {
    initStepOptionListeners();
    initUrlInput();
    initMultiSelect();
    initLeadCapture();
    updateWizardProgress();
    
    // Initialize portfolio animations and winding line
    initAuditPortfolioAnimations();
    initAuditWindingLine();
  });
</script>
